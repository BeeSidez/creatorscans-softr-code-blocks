export default function Block() {
  const [openIndex, setOpenIndex] = useState<number | null>(null);

  const toggleFaq = (index: number) => {
    setOpenIndex(openIndex === index ? null : index);
  };

  const highlightCurrency = (text: string) => {
    const parts = text.split(/(£[0-9,]+\.?[0-9]*|£[0-9,]+|[0-9,]+\+? diamonds?)/g);
    return parts.map((part, i) => {
      if (part.match(/(£[0-9,]+\.?[0-9]*|£[0-9,]+|[0-9,]+\+? diamonds?)/)) {
        return <span key={i} className="text-[#5e7bf6] font-semibold">{part}</span>;
      }
      return part;
    });
  };

  return (
    <div className="container py-12 bg-gradient-to-br from-white via-blue-50/30 to-white">
      <div className="content max-w-4xl mx-auto">
        <h2 className="text-3xl md:text-4xl font-bold text-[#001364] text-center mb-3">
          Frequently Asked Questions
        </h2>
        <p className="text-center text-muted-foreground mb-10">
          Everything you need to know about TikTok diamonds and GBP conversions
        </p>
        
        <div className="space-y-2">
          {faqs.map((faq, index) => {
            const isOpen = openIndex === index;
            const isEven = index % 2 === 0;
            
            return (
              <div
                key={index}
                className={cn(
                  'rounded-lg border border-border overflow-hidden transition-all duration-200',
                  isEven ? 'bg-white' : 'bg-blue-50/30'
                )}
              >
                <button
                  onClick={() => toggleFaq(index)}
                  className="w-full px-6 py-5 flex items-start justify-between gap-4 text-left hover:bg-black/5 transition-colors"
                  aria-expanded={isOpen}
                >
                  <span className="text-[#001364] font-semibold text-base md:text-lg leading-relaxed pr-4">
                    {faq.question}
                  </span>
                  <div className="flex-shrink-0 mt-1">
                    {isOpen ? (
                      <Minus className="w-5 h-5 text-[#5e7bf6] transition-transform duration-200" />
                    ) : (
                      <Plus className="w-5 h-5 text-[#5e7bf6] transition-transform duration-200" />
                    )}
                  </div>
                </button>
                
                <div
                  className={cn(
                    'overflow-hidden transition-all duration-300 ease-in-out',
                    isOpen ? 'max-h-[800px] opacity-100' : 'max-h-0 opacity-0'
                  )}
                >
                  <div className="px-6 pb-5 pt-1">
                    <p className="text-foreground leading-relaxed">
                      {highlightCurrency(faq.answer)}
                    </p>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  );
}
