import { useState } from 'react';
import { Card, CardContent } from "@/components/ui/card";

const currencies = [
  { code: 'GBP', symbol: '\u00a3', rate: 1 },
  { code: 'USD', symbol: '$', rate: 1.27 },
  { code: 'EUR', symbol: '\u20ac', rate: 1.17 },
];

const GBP_PER_DIAMOND = 0.0036;

export default function Block() {
  const [currencyIdx, setCurrencyIdx] = useState(0);
  const currency = currencies[currencyIdx];

  const formatValue = (gbpVal) => {
    const converted = gbpVal * currency.rate;
    if (converted >= 1000) {
      return currency.symbol + converted.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }
    if (converted >= 1) {
      return currency.symbol + converted.toFixed(2);
    }
    return currency.symbol + converted.toFixed(4);
  };

  const formatDiamonds = (gbpAmount) => {
    const diamonds = Math.round(gbpAmount / (GBP_PER_DIAMOND * currency.rate));
    return diamonds.toLocaleString('en-GB') + ' diamonds';
  };

  const conversionData = [
    { diamonds: "100", gbp: "£0.36", pct: 1 },
    { diamonds: "500", gbp: "£1.80", pct: 3 },
    { diamonds: "1,000", gbp: "£3.60", pct: 5 },
    { diamonds: "5,000", gbp: "£18.00", pct: 18 },
    { diamonds: "10,000", gbp: "£36.00", pct: 36, isMinimum: true },
    { diamonds: "20,000", gbp: "£72.00", pct: 50 },
    { diamonds: "50,000", gbp: "£180.00", pct: 75 },
    { diamonds: "100,000", gbp: "£360.00", pct: 100 },
  ];

  const strategies = [
    "Go LIVE during peak hours when your audience is most active",
    "Engage directly with viewers to build gifting relationships",
    "Create gift goals or challenges to encourage participation",
    "Thank gifters immediately and read their usernames aloud",
    "Stream consistently at the same times to build routine viewers",
    "Collaborate with other creators for cross-audience exposure",
    "Use interactive content like Q&As and games",
    "Promote upcoming LIVE sessions in your regular videos",
  ];

  const tiers = [
    { name: "Beginner", followers: "1K-10K followers", diamonds: "1,000-10,000 diamonds", earnings: "£3.60-£36/mo", barPct: 10 },
    { name: "Growing", followers: "10K-50K followers", diamonds: "10,000-50,000 diamonds", earnings: "£36-£180/mo", barPct: 30, featured: true },
    { name: "Established", followers: "50K-100K followers", diamonds: "50,000-200,000 diamonds", earnings: "£180-£720/mo", barPct: 60, featured: true },
    { name: "Top Streamer", followers: "100K+ followers", diamonds: "200,000-1M+ diamonds", earnings: "£720-£3,600+/mo", barPct: 100 },
  ];

  const keyFacts = [
    { label: "What are diamonds?", value: "Virtual currency from LIVE gifts" },
    { label: "How are they earned?", value: "Viewers send gifts during LIVE streams" },
    { label: "Creator share", value: "50% of gift value (TikTok keeps 50%)" },
    { label: "Cash value", value: "£0.0036 per diamond", highlight: true },
    { label: "Withdrawal minimum", value: "£36.00 (10,000 diamonds)", highlight: true },
    { label: "Payout timeline", value: "7-14 business days after request" },
  ];

  const popularConversions = [
    { diamonds: '1,000', baseGBP: 3.60, search: 'How much is 1,000 TikTok diamonds in ' + currency.code + '?' },
    { diamonds: '5,000', baseGBP: 18.00, search: 'How much is 5,000 TikTok diamonds worth in ' + currency.code + '?' },
    { diamonds: '10,000', baseGBP: 36.00, search: 'How much is 10,000 diamonds on TikTok in ' + currency.code + '?', highlight: true, note: 'Minimum withdrawal amount' },
    { diamonds: '20,000', baseGBP: 72.00, search: 'How much is 20,000 TikTok diamonds in ' + currency.code + '?' },
    { diamonds: '50,000', baseGBP: 180.00, search: 'How much is 50K TikTok diamonds worth in ' + currency.code + '?', highlight: true },
    { diamonds: '100,000', baseGBP: 360.00, search: 'How much is 100K diamonds on TikTok in ' + currency.code + '?', highlight: true },
    { diamonds: '200,000', baseGBP: 720.00, search: 'How much is 200K TikTok diamonds worth?' },
    { diamonds: '500,000', baseGBP: 1800.00, search: 'How much is 500K TikTok diamonds in ' + currency.code + '?' },
    { diamonds: '1,000,000', baseGBP: 3600.00, search: 'How much is 1 million TikTok diamonds in ' + currency.code + '?' },
  ];

  const reverseConversions = [
    { amount: 1 },
    { amount: 5 },
    { amount: 10 },
    { amount: 20 },
    { amount: 50 },
    { amount: 100 },
    { amount: 500 },
    { amount: 1000 },
  ].map((row) => ({
    label: currency.symbol + row.amount.toLocaleString('en-GB'),
    diamonds: formatDiamonds(row.amount),
  }));

  return (
    <div style={{ background: 'linear-gradient(180deg, #fafbff 0%, #f8fbff 50%, #fafbff 100%)' }}>
      <div className="container py-12">
        <div className="content">

          {/* SEO-targeted Popular Conversions Section */}
          <div className="mb-10">
            <div className="text-center mb-8">
              <div className="flex items-center justify-center gap-3 mb-3">
                <h2 className="text-3xl md:text-4xl font-bold" style={{ color: '#000f4d' }}>
                  TikTok Diamonds to {currency.code} Conversion Table
                </h2>
                {/* Currency Switcher */}
                <select
                  value={currencyIdx}
                  onChange={(e) => setCurrencyIdx(Number(e.target.value))}
                  className="px-3 py-2 rounded-lg text-sm font-medium cursor-pointer"
                  style={{ backgroundColor: 'rgba(41,79,246,0.1)', border: '1px solid rgba(41,79,246,0.2)', color: '#294ff6', outline: 'none' }}
                >
                  {currencies.map((c, idx) => (
                    <option key={c.code} value={idx} style={{ backgroundColor: '#f8fbff', color: '#000f4d' }}>
                      {c.symbol} {c.code}
                    </option>
                  ))}
                </select>
              </div>
              <p className="text-muted-foreground max-w-2xl mx-auto">
                How much are TikTok diamonds worth in {currency.code}? Use our quick reference table below for instant conversions at the 2026 rate of {formatValue(0.0036)} per diamond.
              </p>
            </div>

            <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
              {/* Diamonds to GBP */}
              <Card className="border-0 shadow-sm overflow-hidden" style={{ backgroundColor: '#f8fbff' }}>
                <div className="px-6 py-5" style={{ background: 'linear-gradient(135deg, #152237 0%, #000f4d 100%)' }}>
                  <h3 className="font-bold text-white text-base">TikTok Diamonds to {currency.code}</h3>
                  <p className="text-xs" style={{ color: '#7a93ff' }}>At the official 2026 rate of {formatValue(0.0036)} per diamond</p>
                </div>
                <CardContent className="p-6">
                  <div className="space-y-0">
                    {popularConversions.map((row, index) => (
                      <div key={index}>
                        <div
                          className="flex items-center justify-between py-3 px-3 rounded-lg"
                          style={{
                            backgroundColor: row.highlight ? 'rgba(41,79,246,0.05)' : 'transparent',
                          }}
                        >
                          <div>
                            <h4 className="font-semibold text-sm" style={{ color: '#000f4d' }}>
                              {row.diamonds} diamonds
                            </h4>
                            {row.note && (
                              <span className="text-xs px-2 py-0.5 rounded-full font-medium" style={{ backgroundColor: '#d8d8ff', color: '#5e7bf6' }}>
                                {row.note}
                              </span>
                            )}
                          </div>
                          <span className="font-bold text-lg" style={{ color: '#294ff6' }}>{formatValue(row.baseGBP)}</span>
                        </div>
                        {index < popularConversions.length - 1 && (
                          <div className="h-px mx-3" style={{ backgroundColor: '#eef4fd' }} />
                        )}
                      </div>
                    ))}
                  </div>
                </CardContent>
              </Card>

              {/* GBP to Diamonds (reverse lookup) */}
