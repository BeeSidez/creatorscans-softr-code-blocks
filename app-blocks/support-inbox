function RequestForm({ type, onCancel, onSubmitted }) {
  const [url, setUrl] = useState("");
  const [notes, setNotes] = useState("");
  const [file, setFile] = useState(null);
  const [submitting, setSubmitting] = useState(false);
  const fileInputRef = useRef(null);

  const createRecord = useRecordCreate({ fields: select });
  const upload = useUpload();

  const isUrlForm = type.form === "url";
  const urlInvalid = isUrlForm && !url.trim();
  const notesInvalid = !isUrlForm && !notes.trim();
  const disabled = submitting || !createRecord.enabled || urlInvalid || notesInvalid;

  const handleSubmit = async () => {
    if (disabled) return;
    setSubmitting(true);
    try {
      const fields = {
        request: type.id,
        status: STATUS_OPTIONS.new.id,
      };
      if (isUrlForm) {
        fields.url = url.trim();
        if (notes.trim()) fields.notes = notes.trim();
      } else {
        fields.notes = notes.trim();
      }
      if (type.allowUpload && file) {
        const uploaded = await upload.mutateAsync(file);
        fields.screenshot = uploaded;
      }
      const created = await createRecord.mutateAsync(fields);
      toast.success("Request sent. We'll reply here shortly.");
      onSubmitted(created);
    } catch (e) {
      toast.error("Could not send request", {
        description: e?.message || "Please try again.",
      });
    } finally {
      setSubmitting(false);
    }
  };

  return (
    <div className="space-y-4">
      <div className="flex items-center gap-3 pb-2">
        <img src={type.icon} alt="" className="w-10 h-10 object-contain" />
        <div>
          <div className="font-semibold text-sm" style={{ color: CS.navy }}>
            {type.label}
          </div>
          <div className="text-xs" style={{ color: CS.muted }}>
            {type.blurb}
          </div>
        </div>
      </div>

      {isUrlForm && (
        <div className="space-y-1.5">
          <Label className="text-xs" style={{ color: CS.navy }}>
            {type.urlLabel} <span style={{ color: CS.red }}>*</span>
          </Label>
          <Input
            type="url"
            value={url}
            onChange={(e) => setUrl(e.target.value)}
            placeholder={type.urlPlaceholder}
            disabled={submitting}
          />
        </div>
      )}

      <div className="space-y-1.5">
        <Label className="text-xs" style={{ color: CS.navy }}>
          {type.detailsLabel}
          {!isUrlForm && <span style={{ color: CS.red }}> *</span>}
        </Label>
        <Textarea
          value={notes}
          onChange={(e) => setNotes(e.target.value)}
          placeholder={type.detailsPlaceholder}
          rows={4}
          disabled={submitting}
        />
      </div>

      {type.allowUpload && (
        <div className="space-y-1.5">
          <Label className="text-xs" style={{ color: CS.navy }}>
            Evidence (optional)
          </Label>
          <input
            ref={fileInputRef}
            type="file"
            accept="image/png,image/jpeg"
            className="hidden"
            onChange={(e) => setFile(e.target.files?.[0] || null)}
          />
          {!file ? (
            <button
              type="button"
              onClick={() => fileInputRef.current?.click()}
              className="w-full py-6 rounded-xl border-2 border-dashed flex flex-col items-center justify-center gap-1 transition-colors"
              style={{ borderColor: CS.border, color: CS.muted, background: CS.light3 }}
              disabled={submitting}
            >
              <Upload size={18} />
              <span className="text-xs">Upload screenshot (PNG or JPEG)</span>
            </button>
          ) : (
            <div
              className="flex items-center justify-between p-3 rounded-xl border"
              style={{ borderColor: CS.border, background: CS.light3 }}
            >
              <span className="text-xs truncate" style={{ color: CS.navy }}>
                {file.name}
              </span>
              <button
                type="button"
                onClick={() => setFile(null)}
                className="p-1 rounded"
                disabled={submitting}
                aria-label="Remove file"
              >
                <X size={14} />
              </button>
            </div>
          )}
        </div>
      )}

      <DialogFooter className="gap-2 pt-2">
        <Button type="button" variant="outline" onClick={onCancel} disabled={submitting}>
          Cancel
        </Button>
        <Button
          type="button"
          onClick={handleSubmit}
          disabled={disabled}
          style={{ background: CS.navy, color: "#fff" }}
        >
          {submitting ? "Sending..." : "Send request"}
        </Button>
      </DialogFooter>
    </div>
  );
}

function NewRequestDialog({ open, onOpenChange, onCreated }) {
  const [stage, setStage] = useState("pick");
  const [picked, setPicked] = useState(null);

  const handleOpenChange = (v) => {
    if (!v) {
      setStage("pick");
      setPicked(null);
    }
    onOpenChange(v);
  };

  const handlePick = (type) => {
    setPicked(type);
    setStage("form");
  };

  return (
    <Dialog open={open} onOpenChange={handleOpenChange}>
      <DialogContent className="max-w-md">
        <DialogHeader>
          <DialogTitle style={{ color: CS.navy }}>
            {stage === "pick" ? "What do you need?" : "New request"}
          </DialogTitle>
        </DialogHeader>
        {stage === "pick" && <NewRequestPicker onPick={handlePick} />}
        {stage === "form" && picked && (
          <RequestForm
            type={picked}
            onCancel={() => {
              setStage("pick");
              setPicked(null);
            }}
            onSubmitted={(created) => {
              handleOpenChange(false);
              onCreated(created);
            }}
          />
        )}
      </DialogContent>
    </Dialog>
  );
}

// ---- main block ----

export default function Block() {
  const { data, status, refetch } = useRecords({ select, count: 200 });
  const [selectedId, setSelectedId] = useState(null);
  const [dialogOpen, setDialogOpen] = useState(false);
  const [search, setSearch] = useState("");

  const items = useMemo(() => {
    const raw = data?.pages.flatMap((p) => p.items) || [];
    return [...raw].sort((a, b) => {
      const ta = new Date(a.fields.lastUpdatedAt || a.fields.createdAt || a.createdAt || 0).getTime();
      const tb = new Date(b.fields.lastUpdatedAt || b.fields.createdAt || b.createdAt || 0).getTime();
      return tb - ta;
    });
  }, [data]);

  const filteredItems = useMemo(() => {
    const query = search.trim().toLowerCase();
    if (!query) return items;
    return items.filter((r) => {
      const type = getRequestType(r.fields.request);
      const haystack = [r.fields.notes || "", r.fields.response || "", type?.label || ""]
        .join(" ")
        .toLowerCase();
      return haystack.includes(query);
    });
  }, [items, search]);

  // refetch when tab regains focus (picks up new Bev replies, status changes)
  useEffect(() => {
    const onVis = () => {
      if (document.visibilityState === "visible") refetch?.();
    };
    document.addEventListener("visibilitychange", onVis);
    return () => document.removeEventListener("visibilitychange", onVis);
  }, [refetch]);

  // if the currently-selected request changes in the background, re-dispatch so the
  // conversation block picks up new status / lastUpdated
  useEffect(() => {
    if (!selectedId) return;
    const match = items.find((r) => r.id === selectedId);
    if (match) dispatchSelection(match);
  }, [items, selectedId]);

  const handleSelect = (record) => {
    setSelectedId(record.id);
    dispatchSelection(record);
  };

  const handleCreated = async (created) => {
    await refetch?.();
    if (created?.id) {
      setSelectedId(created.id);
      dispatchSelection(created, true);
    }
  };

  const isLoading = status === "pending";
  const hasAny = items.length > 0;

  return (
    <div className="container py-6" style={{ color: CS.navy }}>
      <div
        className="overflow-hidden rounded-2xl border"
        style={{ borderColor: CS.border, background: "#fff" }}
      >
        {/* header */}
        <div
          className="flex items-center justify-between px-5 py-3 border-b"
          style={{ borderColor: CS.border, background: CS.light3 }}
        >
          <div className="flex items-center gap-2">
            <Inbox size={18} color={CS.navy} />
            <span className="font-semibold text-sm" style={{ color: CS.navy }}>
              Support
            </span>
            {hasAny && (
              <span className="text-xs" style={{ color: CS.muted }}>
                {items.length} request{items.length === 1 ? "" : "s"}
              </span>
            )}
          </div>
          <Button
            onClick={() => setDialogOpen(true)}
            size="sm"
            style={{ background: CS.navy, color: "#fff" }}
          >
            <Plus size={16} className="mr-1" /> New request
          </Button>
        </div>

        {items.length >= 5 && (
          <div className="px-4 py-2 border-b" style={{ borderColor: CS.border, background: "#fff" }}>
            <div className="relative">
              <Search size={14} color={CS.muted} className="absolute left-2.5 top-1/2 -translate-y-1/2" />
              <Input
                value={search}
                onChange={(e) => setSearch(e.target.value)}
                placeholder="Search requests"
                className="pl-8 h-8 text-sm"
              />
            </div>
          </div>
        )}

        {isLoading ? (
          <div className="p-10 text-center text-sm" style={{ color: CS.muted }}>
            Loading your requests…
          </div>
        ) : !hasAny ? (
          <EmptyInbox onNew={() => setDialogOpen(true)} />
        ) : (
          <div style={{ maxHeight: 380 }} className="overflow-y-auto">
            {filteredItems.length === 0 ? (
              <div className="p-6 text-center text-xs" style={{ color: CS.muted }}>
                No matches.
              </div>
            ) : (
              filteredItems.map((r) => (
                <RequestRow
                  key={r.id}
                  record={r}
                  active={r.id === selectedId}
                  onClick={() => handleSelect(r)}
                />
              ))
            )}
          </div>
        )}
      </div>

      <NewRequestDialog open={dialogOpen} onOpenChange={setDialogOpen} onCreated={handleCreated} />
    </div>
  );
}
