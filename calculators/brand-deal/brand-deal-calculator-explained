      name: 'Standard Add-ons (+25-50%)',
      items: ['Instagram Story', 'Link in bio', 'Behind-the-scenes content'],
      color: '#4466f8',
      tag: '+25-50%',
    },
    {
      name: 'Premium Add-ons (+50-100%)',
      items: ['Paid ad rights', 'Whitelisting', 'Exclusivity', 'Multiple videos'],
      color: '#5e7bf6',
      tag: '+50-100%',
