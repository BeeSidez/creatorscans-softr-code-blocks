          <Card className="bg-white" style={{ borderColor: CS_BORDER }}>
            <CardContent className="p-8 space-y-8">

              {/* ─── 1. Welcome ─── */}
              {step.id === "welcome" && (
                <>
                  <StepHeading
                    eyebrow="Welcome"
                    title={`Hey ${data.fields.fullName?.split(" ")[0] || "there"} — let's get you set up.`}
                    description="A few quick questions to set up your account, then we'll connect your TikTok and you're in. Most people finish in under 3 minutes."
                  />
                  <div className="rounded-xl p-5 space-y-3" style={{ backgroundColor: CS_BORDER }}>
                    <div className="flex items-center gap-3 text-sm" style={{ color: CS_BLUE }}>
                      <Sparkles className="h-4 w-4" /> What we'll cover
                    </div>
                    <ul className="space-y-2 text-sm text-muted-foreground">
                      <li>• Your TikTok handle and the content you post</li>
                      <li>• Your weekly posting commitment</li>
                      <li>• A few profile basics so we can match you to brands</li>
                      <li>• Connect TikTok at the end</li>
                    </ul>
                  </div>
                  <NavBar
                    onContinue={continueWelcome}
                    canContinue
                    showBack={false}
                    continueLabel="Let's go"
                  />
                </>
              )}

              {/* ─── 2. TikTok handle ─── */}
              {step.id === "tiktok" && (
                <>
                  <StepHeading
                    eyebrow="Step 1"
                    title="What's your TikTok handle?"
                    description="The username people find you under on TikTok. We use this to verify you and pull your stats once you connect."
                  />
                  <div className="space-y-2">
                    <Label htmlFor="tiktok-handle">TikTok username</Label>
                    <div className="flex items-center gap-2">
                      <span className="text-lg text-muted-foreground">@</span>
                      <Input
                        id="tiktok-handle"
                        value={form.tiktokUsername.replace(/^@/, "")}
                        onChange={(e) => set("tiktokUsername", e.target.value)}
                        placeholder="yourhandle"
                        className="text-base"
                      />
                    </div>
                  </div>
                  <NavBar
                    onBack={goBack}
                    onContinue={continueTiktok}
                    isSaving={saving}
                    canContinue={!!form.tiktokUsername.trim()}
                    showBack={showBack}
                  />
                </>
              )}

              {/* ─── 3. Track ─── */}
              {step.id === "track" && (
                <>
                  <StepHeading
                    eyebrow="Step 2"
                    title="What kind of content do you post?"
                    description="Pick everything you do. You can change this later. Each one you pick gets its own posting commitment in the next step."
                  />
                  <div className="grid sm:grid-cols-3 gap-3">
                    {TRACK_OPTIONS.map((opt) => (
                      <TrackTile
                        key={opt.key}
                        option={opt}
                        selected={form.track.includes(opt.key)}
                        onToggle={() => toggleInArray("track", opt.key)}
                      />
                    ))}
                  </div>
                  <NavBar
                    onBack={goBack}
                    onContinue={continueTrack}
                    isSaving={saving}
                    canContinue={form.track.length > 0}
                    showBack={showBack}
                  />
                </>
              )}

              {/* ─── 4. Cadence (membership tier picker) ─── */}
              {step.id === "cadence" && (
                <>
                  <StepHeading
                    eyebrow="Step 3"
                    title="Pick your weekly intensity."
                    description="Each track has three levels. Pick the one you can realistically commit to. You can change it later."
                  />
                  <div className="space-y-6">
                    {TRACK_OPTIONS.filter((t) => form.track.includes(t.key)).map((t) => {
                      // Filter Memberships rows by Track Type UUID match
                      const optionsForTrack = allMemberships.filter(
                        (m) => selectId(m.fields?.trackType) === t.membershipTrackTypeId,
                      );
                      // Sort by tier display order (Starter -> Pro -> Advanced -> Custom)
                      const sorted = [...optionsForTrack].sort(
                        (a, b) =>
                          (TIER_ORDER_BY_ID[selectId(a.fields?.tier)] ?? 99) -
                          (TIER_ORDER_BY_ID[selectId(b.fields?.tier)] ?? 99),
                      );
                      return (
                        <div key={t.key}>
                          <div className="flex items-center gap-2 mb-3">
                            <div
                              className="rounded-lg p-1.5"
                              style={{ backgroundColor: CS_BORDER, color: CS_BLUE }}
                            >
                              <t.Icon className="h-4 w-4" />
                            </div>
                            <div className="font-semibold text-sm" style={{ color: CS_BLUE }}>
                              {t.label}
                            </div>
                          </div>
                          {sorted.length === 0 ? (
                            <div className="text-xs text-muted-foreground italic">
                              No membership tiers found for {t.label}. Check the Memberships table.
                            </div>
                          ) : (
                            <div className="grid grid-cols-3 gap-2">
                              {sorted.map((m) => {
                                const tierId = selectId(m.fields?.tier);
                                const tierLabel = TIER_LABEL_BY_ID[tierId] || m.title || "";
                                const cadence =
                                  t.key === "live"
                                    ? m.fields?.livesPerWeek
                                    : m.fields?.postsPerWeek;
                                const unit = t.key === "live" ? "lives" : "posts";
                                const selected = form.membershipsByTrack[t.key] === m.id;
                                return (
                                  <button
                                    key={m.id}
                                    type="button"
                                    onClick={() =>
                                      setForm((f) => ({
                                        ...f,
                                        membershipsByTrack: {
                                          ...f.membershipsByTrack,
                                          [t.key]: m.id,
                                        },
                                      }))
                                    }
                                    className="text-left transition-all rounded-xl p-3 border-2"
                                    style={{
                                      borderColor: selected ? CS_PINK : CS_BORDER,
                                      backgroundColor: selected
                                        ? "rgba(254,44,85,0.04)"
                                        : "#fff",
                                    }}
                                  >
                                    <div
                                      className="text-xs font-bold uppercase tracking-wider mb-1"
                                      style={{ color: selected ? CS_PINK : CS_BLUE }}
                                    >
                                      {tierLabel}
                                    </div>
                                    {cadence != null && (
                                      <div className="text-xs text-muted-foreground">
                                        {cadence} {unit}/wk
                                      </div>
                                    )}
                                  </button>
                                );
                              })}
                            </div>
                          )}
                        </div>
                      );
                    })}
                  </div>
                  <NavBar
                    onBack={goBack}
                    onContinue={continueCadence}
                    isSaving={saving}
                    canContinue={
                      TRACK_OPTIONS.filter((t) => form.track.includes(t.key)).every(
                        (t) => !!form.membershipsByTrack[t.key],
                      )
                    }
                    showBack={showBack}
                  />
                </>
              )}

              {/* ─── 5. About you ─── */}
              {step.id === "about" && (
                <>
                  <StepHeading
                    eyebrow="Step 4"
                    title="A bit about you"
                    description="Used to match you to brands and content opportunities. Age and gender are required so we can verify partnership eligibility."
                  />
                  <div className="grid sm:grid-cols-2 gap-4">
                    <div className="space-y-2">
                      <Label>Age</Label>
                      <Select value={form.age} onValueChange={(v) => set("age", v)}>
                        <SelectTrigger><SelectValue placeholder="Pick one" /></SelectTrigger>
                        <SelectContent>
                          {AGE_OPTIONS.map((o) => (
                            <SelectItem key={o.id} value={o.id}>{o.label}</SelectItem>
                          ))}
                        </SelectContent>
                      </Select>
                    </div>
                    <div className="space-y-2">
                      <Label>Gender</Label>
                      <Select value={form.gender} onValueChange={(v) => set("gender", v)}>
                        <SelectTrigger><SelectValue placeholder="Pick one" /></SelectTrigger>
                        <SelectContent>
                          {GENDER_OPTIONS.map((o) => (
                            <SelectItem key={o.id} value={o.id}>{o.label}</SelectItem>
                          ))}
                        </SelectContent>
                      </Select>
                    </div>
                    <div className="space-y-2">
                      <Label>Pronouns <span className="text-xs text-muted-foreground">(optional)</span></Label>
                      <Select value={form.pronouns} onValueChange={(v) => set("pronouns", v)}>
                        <SelectTrigger><SelectValue placeholder="Pick one" /></SelectTrigger>
                        <SelectContent>
                          {PRONOUNS_OPTIONS.map((o) => (
                            <SelectItem key={o.id} value={o.id}>{o.label}</SelectItem>
                          ))}
                        </SelectContent>
                      </Select>
                    </div>
                    <div className="space-y-2">
                      <Label>Birthday <span className="text-xs text-muted-foreground">(optional)</span></Label>
                      <Input
                        type="date"
                        value={form.birthday}
                        onChange={(e) => set("birthday", e.target.value)}
                      />
                    </div>
                  </div>
                  <NavBar
                    onBack={goBack}
                    onContinue={continueAbout}
                    isSaving={saving}
                    canContinue={!!form.age && !!form.gender}
                    showBack={showBack}
                  />
                </>
              )}

              {/* ─── 6. Where you're from ─── */}
              {step.id === "where" && (
                <>
                  <StepHeading
                    eyebrow="Step 5"
                    title="Where you're from"
                    description="Helps us match you to regional brand campaigns and content opportunities. All optional — skip if you'd rather not say."
                  />
                  <div className="grid sm:grid-cols-2 gap-4">
                    <div className="space-y-2">
                      <Label>City</Label>
                      <Input
                        value={form.city}
                        onChange={(e) => set("city", e.target.value)}
                        placeholder="Manchester"
                      />
                    </div>
                    <div className="space-y-2">
                      <Label>Regional accent</Label>
                      <Select value={form.regionalAccent} onValueChange={(v) => set("regionalAccent", v)}>
                        <SelectTrigger><SelectValue placeholder="Pick one" /></SelectTrigger>
                        <SelectContent>
                          {REGIONAL_ACCENT_OPTIONS.map((o) => (
                            <SelectItem key={o.id} value={o.id}>{o.label}</SelectItem>
                          ))}
                        </SelectContent>
                      </Select>
                    </div>
                    <div className="space-y-2">
                      <Label>Heritage</Label>
                      <Input
                        value={form.heritage}
                        onChange={(e) => set("heritage", e.target.value)}
                        placeholder="British-Ghanaian"
                      />
                    </div>
                    <div className="space-y-2">
                      <Label>First language</Label>
                      <Input
                        value={form.firstLanguage}
                        onChange={(e) => set("firstLanguage", e.target.value)}
                        placeholder="English"
                      />
                    </div>
                    <div className="sm:col-span-2 flex items-start gap-3 rounded-xl p-4" style={{ backgroundColor: CS_BORDER }}>
                      <Checkbox
                        id="localDialect"
                        checked={form.localDialect}
                        onCheckedChange={(c) => set("localDialect", !!c)}
                        className="mt-0.5"
                      />
                      <div>
                        <Label htmlFor="localDialect" className="cursor-pointer">
                          I post in my local dialect
                        </Label>
                        <p className="text-xs text-muted-foreground mt-0.5">
                          Helpful for regional brand fit.
                        </p>
                      </div>
                    </div>
                  </div>
                  <NavBar
                    onBack={goBack}
                    onContinue={continueWhere}
                    onSkip={skipStep}
                    isSaving={saving}
                    canContinue
                    showBack={showBack}
                    showSkip
                  />
                </>
              )}

              {/* ─── 7. Career ─── */}
              {step.id === "career" && (
                <>
                  <StepHeading
                    eyebrow="Step 6"
                    title="Your career"
                    description="Helps us route you to relevant brand deals and content angles. All optional."
                  />
                  <div className="space-y-5">
                    <div className="space-y-2">
                      <Label>Job title</Label>
                      <Input
                        value={form.jobTitle}
                        onChange={(e) => set("jobTitle", e.target.value)}
                        placeholder="Marketing Manager"
                      />
                    </div>
                    <div className="space-y-2">
                      <Label>Industry <span className="text-xs text-muted-foreground">(pick all that apply)</span></Label>
                      <div className="flex flex-wrap gap-2">
                        {INDUSTRY_OPTIONS.map((o) => (
                          <MultiChip
                            key={o.id}
                            option={o}
                            selected={form.industry.includes(o.id)}
                            onToggle={() => toggleInArray("industry", o.id)}
                          />
                        ))}
                      </div>
                    </div>
                    <div className="space-y-2">
                      <Label>Position <span className="text-xs text-muted-foreground">(pick all that apply)</span></Label>
                      <div className="flex flex-wrap gap-2">
                        {POSITION_OPTIONS.map((o) => (
                          <MultiChip
                            key={o.id}
                            option={o}
                            selected={form.position.includes(o.id)}
                            onToggle={() => toggleInArray("position", o.id)}
                          />
                        ))}
                      </div>
                    </div>
                    <div className="space-y-2">
                      <Label>Career stage <span className="text-xs text-muted-foreground">(pick all that apply)</span></Label>
                      <div className="flex flex-wrap gap-2">
                        {CAREER_STAGE_OPTIONS.map((o) => (
                          <MultiChip
                            key={o.id}
                            option={o}
                            selected={form.careerStage.includes(o.id)}
                            onToggle={() => toggleInArray("careerStage", o.id)}
                          />
                        ))}
                      </div>
                    </div>
                    <div className="space-y-2">
                      <Label>Annual income</Label>
                      <Select value={form.income} onValueChange={(v) => set("income", v)}>
                        <SelectTrigger><SelectValue placeholder="Pick a band" /></SelectTrigger>
                        <SelectContent>
                          {INCOME_OPTIONS.map((o) => (
                            <SelectItem key={o.id} value={o.id}>{o.label}</SelectItem>
                          ))}
                        </SelectContent>
                      </Select>
                    </div>
                  </div>
                  <NavBar
                    onBack={goBack}
                    onContinue={continueCareer}
                    onSkip={skipStep}
                    isSaving={saving}
                    canContinue
                    showBack={showBack}
                    showSkip
                  />
                </>
              )}

              {/* ─── 8. Why you're here ─── */}
              {step.id === "why" && (
                <>
                  <StepHeading
                    eyebrow="Step 7"
                    title="Why you're here"
                    description="What you want out of Creator Scans. We use this to surface the right tools, perks, and brand opportunities for you."
                  />
                  <div className="space-y-5">
                    <div className="space-y-2">
                      <Label>What are you looking for? <span className="text-xs text-muted-foreground">(pick as many as apply)</span></Label>
                      <div className="flex flex-wrap gap-2">
                        {LOOKING_FOR_OPTIONS.map((o) => (
                          <MultiChip
                            key={o.id}
                            option={o}
                            selected={form.lookingFor.includes(o.id)}
                            onToggle={() => toggleInArray("lookingFor", o.id)}
                          />
                        ))}
                      </div>
                    </div>
                    <div className="space-y-2">
                      <Label htmlFor="myGoal">In one line, what's your goal?</Label>
                      <Textarea
                        id="myGoal"
                        value={form.myGoal}
                        onChange={(e) => set("myGoal", e.target.value)}
                        placeholder="Quit my 9-5 by next April."
                        rows={3}
                      />
                    </div>
                  </div>
                  <NavBar
                    onBack={goBack}
                    onContinue={continueWhy}
                    onSkip={skipStep}
                    isSaving={saving}
                    canContinue
                    showBack={showBack}
                    showSkip
                  />
                </>
              )}

              {/* ─── 9. Connect TikTok ─── */}
              {step.id === "connect" && (
                <>
                  <StepHeading
                    eyebrow="Last step"
                    title="Connect your TikTok."
                    description="We use TikTok's official auth to pull your bio, profile picture, and stats — and to send your TikTok Shop / Creator Network agency invite. Takes about 30 seconds."
                  />
                  <div className="space-y-3">
                    <div className="flex items-start gap-3 rounded-xl p-4" style={{ backgroundColor: CS_BORDER }}>
                      <Check className="h-5 w-5 mt-0.5 shrink-0" style={{ color: CS_BLUE }} />
                      <div className="text-sm" style={{ color: CS_BLUE }}>
                        Pulls your handle, bio, follower count and profile picture automatically.
                      </div>
                    </div>
                    <div className="flex items-start gap-3 rounded-xl p-4" style={{ backgroundColor: CS_BORDER }}>
                      <Check className="h-5 w-5 mt-0.5 shrink-0" style={{ color: CS_BLUE }} />
                      <div className="text-sm" style={{ color: CS_BLUE }}>
                        Triggers your TikTok Shop and Creator Network agency invite.
                      </div>
                    </div>
                    <div className="flex items-start gap-3 rounded-xl p-4" style={{ backgroundColor: CS_BORDER }}>
                      <Check className="h-5 w-5 mt-0.5 shrink-0" style={{ color: CS_BLUE }} />
                      <div className="text-sm" style={{ color: CS_BLUE }}>
                        Read-only. We can't post or DM as you.
                      </div>
                    </div>
                  </div>
                  <NavBar
                    onBack={goBack}
                    onContinue={handleConnectTikTok}
                    isSaving={saving}
                    canContinue
                    showBack={showBack}
                    continueLabel="Connect TikTok"
                  />
                  <p className="text-xs text-muted-foreground text-center">
                    You'll be redirected to TikTok to authorise. After approval you'll land back in the dashboard.
                  </p>
                </>
              )}

            </CardContent>
          </Card>
        </div>
      </div>
    </>
  );
}
