// ---- helpers ----

const readLabel = (val) => {
  if (!val) return null;
  if (typeof val === "string") return val;
  if (Array.isArray(val)) return val[0]?.label || val[0]?.name || val[0] || null;
  return val.label || val.name || null;
};

const readId = (val) => {
  if (!val) return null;
  if (typeof val === "string") return val;
  if (Array.isArray(val)) return val[0]?.id || null;
  return val.id || null;
};

const getStatusStyle = (statusVal) => {
  const label = readLabel(statusVal);
  if (label === "Resolved") return STATUS_OPTIONS.resolved;
  if (label === "In progress") return STATUS_OPTIONS.inProgress;
  return STATUS_OPTIONS.new;
};

const getRequestType = (requestVal) => {
  const id = readId(requestVal);
  const label = readLabel(requestVal);
  return Object.values(REQUEST_TYPES).find((t) => t.id === id || t.label === label) || null;
};

const relativeTime = (iso) => {
  if (!iso) return "";
  const then = new Date(iso).getTime();
  const now = Date.now();
  const diff = Math.max(0, now - then);
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return "just now";
  if (mins < 60) return mins + "m";
  const hours = Math.floor(mins / 60);
  if (hours < 24) return hours + "h";
  const days = Math.floor(hours / 24);
  if (days === 1) return "yesterday";
  if (days < 7) return days + "d";
  const d = new Date(iso);
  const month = d.toLocaleString("en-GB", { month: "short" });
  return d.getDate() + " " + month;
};

const truncate = (s, n) => {
  if (!s) return "";
  return s.length > n ? s.slice(0, n - 1) + "…" : s;
};

// Share selection with the support-conversation block on the same page
function dispatchSelection(record, justCreated = false) {
  window.dispatchEvent(
    new CustomEvent("cs-request-selected", {
      detail: {
        id: record.id,
        justCreated,
        fields: record.fields,
        createdAt: record.fields.createdAt || record.createdAt,
      },
    })
  );
}

