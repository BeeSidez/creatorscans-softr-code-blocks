import { useState } from "react";
import { useCurrentUser } from "@/lib/user";
import { useRecordCreate, q } from "@/lib/datasource";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import {
  Dialog,
  DialogContent,
  DialogHeader,
  DialogTitle,
  DialogDescription,
  DialogFooter,
} from "@/components/ui/dialog";
import { Check, Handshake } from "lucide-react";
import { toast } from "sonner";
import { Toaster } from "@/components/ui/sonner";

// ─── Brand palette ────────────────────────────────────────────────
const CS_NAVY = "#001364";
const CS_PERIWINKLE = "#7a93ff";
const CS_BORDER = "#eef4fd";
const CS_MUTED = "#6b7a99";

// ─── Field map (Requests table) ───────────────────────────────────
// SOURCE TAB IN SOFTR MUST BE SET TO THE REQUESTS TABLE.
// Field IDs come from the existing support-inbox block.
const select = q.select({
  notes: "cy26q",      // long text — the message body the user can edit
  request: "zPHQj",    // SELECT — request subject (Payment and billing question)
  // type: "<<TYPE_FIELD_ID>>",  // see TODO below
});

// ─── Option UUIDs ─────────────────────────────────────────────────
// PASTE THE REAL UUIDs from your Requests table options.
// Both fields are select-type, so Softr expects { id, label } objects.
const REQUEST_PAYMENT_BILLING = {
  id: "<<paste option UUID for 'Payment and billing question'>>",
  label: "Payment and billing question",
};

// If you also have a separate "type" field with a "support" option, fill
// in BOTH the field ID above (uncomment the line) AND the option below.
// Otherwise leave commented out and the request will save without a type.
// const TYPE_SUPPORT = {
//   id: "<<paste option UUID for 'support'>>",
//   label: "support",
// };

const FEE_PERCENT = "10%";

const FEATURES = [
  "Full Academy access",
  "AI scripts, remix, and content feedback",
  "Sample vouchers and product samples",
  "Higher commission rates from brands",
  "Brand campaign access",
  "Violation support and escalation",
  "Performance bonuses",
  "Priority support",
];

const PREFILLED_MESSAGE = `Hi, I'd like to set up the 10% fee agreement so I can access agency membership.

Please send me the next steps.

Thanks!`;

export default function Block() {
  const [dialogOpen, setDialogOpen] = useState(false);
  const [submitting, setSubmitting] = useState(false);

  const user = useCurrentUser();
  const createRecord = useRecordCreate({ fields: select });

  const handleSubmit = async () => {
    if (!user?.id) {
      toast.error("You need to be signed in to send a request.");
      return;
    }
    if (createRecord.enabled === false) {
      toast.error(
        "This block can't write to Requests. Check the Source tab in Softr is set to the Requests table.",
      );
      return;
    }

    setSubmitting(true);
    try {
      // Both notes and request are hidden from the user. The user sees the
      // resulting record later in their support inbox / messages.
      const fields = {
        notes: PREFILLED_MESSAGE,
        request: REQUEST_PAYMENT_BILLING,
        // type: TYPE_SUPPORT,  // uncomment once you've filled the constants above
      };
      console.log("=== fee-wall request payload:", JSON.stringify(fields, null, 2));
      await createRecord.mutateAsync(fields);
      toast.success("Request sent. We'll be in touch shortly.");
      setDialogOpen(false);
    } catch (e) {
      console.error("=== fee-wall request error:", e);
      toast.error("Couldn't send request", {
        description: e?.message || "Open the browser console for details.",
      });
    }
    setSubmitting(false);
  };

  return (
    <>
      <Toaster />
      <div className="content mx-auto py-4" style={{ maxWidth: 1140 }}>
        {/* ── Header ── */}
        <div className="text-center mb-8 space-y-3">
          <div
            className="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-wider"
            style={{
              backgroundColor: "rgba(122,147,255,0.10)",
              color: CS_PERIWINKLE,
              border: `1px solid ${CS_PERIWINKLE}40`,
            }}
          >
            <Handshake className="h-3 w-3" />
            Agency membership
          </div>
          <h1 className="text-3xl md:text-4xl font-bold" style={{ color: CS_NAVY }}>
            No subscription. Just a fair commission.
          </h1>
          <p className="text-base max-w-2xl mx-auto" style={{ color: CS_MUTED }}>
            You're earning enough that a flat commission makes more sense than a subscription. Send a quick request to set up the fee agreement and unlock everything Creator Scans has to offer.
          </p>
        </div>

        {/* ── Card ── */}
        <div className="flex justify-center">
          <Card
            className="w-full max-w-md"
            style={{
              borderColor: `${CS_PERIWINKLE}55`,
              borderWidth: 2,
              borderRadius: 16,
            }}
          >
            <CardHeader className="pb-4">
              <CardTitle className="text-xl font-semibold" style={{ color: CS_NAVY }}>
                Agency membership
              </CardTitle>
            </CardHeader>
            <CardContent className="space-y-6">
              {/* Fee */}
              <div>
                <div className="font-extrabold" style={{ color: CS_NAVY, fontSize: 36, lineHeight: 1 }}>
                  {FEE_PERCENT}
                  <span className="text-lg font-normal ml-1" style={{ color: CS_MUTED }}>
                    commission
                  </span>
                </div>
                <p className="text-sm mt-2" style={{ color: CS_MUTED }}>
                  On TikTok Shop sales. No subscription, ever.
                </p>
              </div>

              {/* Features */}
              <ul className="space-y-3">
                {FEATURES.map((feature, i) => (
                  <li key={i} className="flex items-start gap-3">
                    <Check
                      className="h-4 w-4 mt-0.5 shrink-0"
                      style={{ color: CS_PERIWINKLE }}
                      strokeWidth={3}
                    />
                    <span className="text-sm" style={{ color: CS_NAVY }}>
                      {feature}
                    </span>
                  </li>
                ))}
              </ul>

              {/* CTA — opens modal */}
              <Button
                onClick={() => setDialogOpen(true)}
                className="w-full font-semibold rounded-lg"
                style={{
                  backgroundColor: CS_PERIWINKLE,
                  color: "#fff",
                  paddingTop: 14,
                  paddingBottom: 14,
                  fontSize: 15,
                  border: "none",
                }}
              >
                Request fee agreement
              </Button>
              <p className="text-xs text-center" style={{ color: CS_MUTED }}>
                We'll get back to you in your support inbox.
              </p>
            </CardContent>
          </Card>
        </div>
      </div>

      {/* ── Confirmation modal (no editable fields) ── */}
      <Dialog open={dialogOpen} onOpenChange={setDialogOpen}>
        <DialogContent className="sm:max-w-md">
          <DialogHeader>
            <DialogTitle style={{ color: CS_NAVY }}>
              Request your fee agreement?
            </DialogTitle>
            <DialogDescription>
              We'll create a support request to set up your 10% agreement and send the next steps to your inbox. You can track the response in your messages.
            </DialogDescription>
          </DialogHeader>

          <DialogFooter>
            <Button
              variant="ghost"
              onClick={() => setDialogOpen(false)}
              disabled={submitting}
              style={{ color: CS_MUTED }}
            >
              Cancel
            </Button>
            <Button
              onClick={handleSubmit}
              disabled={submitting}
              className="font-semibold"
              style={{ backgroundColor: CS_PERIWINKLE, color: "#fff" }}
            >
              {submitting ? "Sending…" : "Send request"}
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    </>
  );
}
