import { useState, useEffect, useRef } from 'react';
import { Card, CardContent } from '@/components/ui/card';
import { TrendingUp, Calendar, Calculator, Info, DollarSign, ArrowDown, Percent, ShieldX } from 'lucide-react';

const currencies = [
  { code: 'GBP', symbol: '\u00a3', rate: 1 },
  { code: 'USD', symbol: '$', rate: 1.27 },
  { code: 'EUR', symbol: '\u20ac', rate: 1.17 },
];

export default function Block() {
  const [gmvSoFar, setGmvSoFar] = useState(8000);
  const [dayOfMonth, setDayOfMonth] = useState(new Date().getDate());
  const [commissionRate, setCommissionRate] = useState(8);
  const [agencyFee, setAgencyFee] = useState(20);
  const [refundRate, setRefundRate] = useState(8);
  const [currencyIdx, setCurrencyIdx] = useState(0);

  const [animatedNet, setAnimatedNet] = useState(0);
  const [animatedProjectedGMV, setAnimatedProjectedGMV] = useState(0);
  const [animatedGross, setAnimatedGross] = useState(0);
  const [animatedAgencyCut, setAnimatedAgencyCut] = useState(0);
  const animFrameRef = useRef(null);

  const currency = currencies[currencyIdx];

  const daysInMonth = new Date(new Date().getFullYear(), new Date().getMonth() + 1, 0).getDate();
  const dailyGMV = dayOfMonth > 0 ? gmvSoFar / dayOfMonth : 0;
  const projectedMonthGMV = dailyGMV * daysInMonth;
  const grossCommission = projectedMonthGMV * (commissionRate / 100);
  const afterRefunds = grossCommission * (1 - refundRate / 100);
  const agencyCut = afterRefunds * (agencyFee / 100);
  const netTakeHome = afterRefunds - agencyCut;

  useEffect(() => {
    const startNet = animatedNet;
    const startGMV = animatedProjectedGMV;
    const startGross = animatedGross;
    const startAgency = animatedAgencyCut;
    const duration = 400;
    const startTime = Date.now();

    const animate = () => {
      const elapsed = Date.now() - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const ease = 1 - Math.pow(1 - progress, 3);

      setAnimatedNet(startNet + (netTakeHome - startNet) * ease);
      setAnimatedProjectedGMV(startGMV + (projectedMonthGMV - startGMV) * ease);
      setAnimatedGross(startGross + (grossCommission - startGross) * ease);
      setAnimatedAgencyCut(startAgency + (agencyCut - startAgency) * ease);

      if (progress < 1) {
        animFrameRef.current = requestAnimationFrame(animate);
      }
    };

    if (animFrameRef.current) cancelAnimationFrame(animFrameRef.current);
    animFrameRef.current = requestAnimationFrame(animate);

    return () => {
      if (animFrameRef.current) cancelAnimationFrame(animFrameRef.current);
    };
  }, [netTakeHome, projectedMonthGMV, grossCommission, agencyCut]);

  const convert = (val) => val * currency.rate;

  const formatCurrency = (val) => {
    const converted = convert(val);
    if (currency.rate >= 50) {
      return currency.symbol + Math.round(converted).toLocaleString('en-GB');
    }
    return currency.symbol + converted.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  };

  const formatWhole = (val) => {
    const converted = val * currency.rate;
    return currency.symbol + Math.round(converted).toLocaleString('en-GB');
  };

  const sliderTrackStyle = (value, min, max) => {
    const pct = ((value - min) / (max - min)) * 100;
    return {
      background: `linear-gradient(to right, #294ff6 0%, #5e7bf6 ${pct}%, #eef4fd ${pct}%, #eef4fd 100%)`,
    };
  };

  const waterfallSteps = [
    { label: 'Projected Month GMV', value: projectedMonthGMV, color: '#294ff6' },
    { label: 'Gross Commission (' + commissionRate + '%)', value: grossCommission, color: '#4466f8' },
    { label: 'After Refunds (-' + refundRate + '%)', value: afterRefunds, color: '#5e7bf6' },
    { label: 'After Agency (-' + agencyFee + '%)', value: netTakeHome, color: '#000f4d' },
  ];
  const maxWaterfall = projectedMonthGMV || 1;

  return (
    <div style={{ background: 'linear-gradient(180deg, #fafbff 0%, #f8fbff 50%, #fafbff 100%)' }}>
      <div className="container py-16">
        <div className="content max-w-5xl mx-auto space-y-8">

          {/* Calculator Card */}
          <Card className="border-0 shadow-lg overflow-hidden" style={{ backgroundColor: '#f8fbff' }}>
            {/* Card Header */}
            <div className="px-8 py-6" style={{ background: 'linear-gradient(135deg, #152237 0%, #000f4d 100%)' }}>
              <div className="flex items-center justify-between flex-wrap gap-4">
                <div className="flex items-center gap-3">
                  <div className="w-10 h-10 rounded-xl flex items-center justify-center" style={{ backgroundColor: 'rgba(41,79,246,0.2)' }}>
                    <Calculator className="w-5 h-5" style={{ color: '#7a93ff' }} />
                  </div>
                  <div>
                    <h2 className="text-xl font-bold text-white">Take Home Pay Calculator</h2>
                    <p className="text-sm" style={{ color: '#7a93ff' }}>See what you actually keep after fees, refunds, and agency cuts</p>
                  </div>
                </div>

                {/* Currency Selector */}
                <select
                  value={currencyIdx}
                  onChange={(e) => setCurrencyIdx(Number(e.target.value))}
                  className="px-3 py-2 rounded-lg text-sm font-medium cursor-pointer"
                  style={{ backgroundColor: 'rgba(41,79,246,0.2)', border: '1px solid rgba(122,147,255,0.3)', color: 'white', outline: 'none' }}
                >
                  {currencies.map((c, idx) => (
                    <option key={c.code} value={idx} style={{ backgroundColor: '#152237', color: 'white' }}>
                      {c.symbol} {c.code}
                    </option>
                  ))}
                </select>
              </div>
            </div>

            <CardContent className="p-8 space-y-8">
              {/* Input: GMV So Far This Month */}
              <div className="space-y-3">
                <div className="flex items-center justify-between">
                  <label className="text-sm font-semibold" style={{ color: '#000f4d' }}>GMV So Far This Month</label>
                  <div className="flex items-center gap-1 px-3 py-1.5 rounded-lg" style={{ backgroundColor: '#eef4fd' }}>
                    <span className="text-sm font-bold" style={{ color: '#294ff6' }}>{formatWhole(gmvSoFar)}</span>
                  </div>
                </div>
                <input
                  type="range"
                  min="0"
                  max="200000"
                  step="500"
                  value={gmvSoFar}
                  onChange={(e) => setGmvSoFar(Number(e.target.value))}
                  className="cs-slider"
                  style={sliderTrackStyle(gmvSoFar, 0, 200000)}
                />
                <div className="flex justify-between text-xs text-muted-foreground">
                  <span>{currency.symbol}0</span>
                  <span>{formatWhole(200000)}</span>
                </div>
              </div>

              {/* Input: Day of Month */}
              <div className="space-y-3">
                <div className="flex items-center justify-between">
                  <label className="text-sm font-semibold" style={{ color: '#000f4d' }}>Day of Month</label>
                  <div className="flex items-center gap-1 px-3 py-1.5 rounded-lg" style={{ backgroundColor: '#eef4fd' }}>
                    <span className="text-sm font-bold" style={{ color: '#294ff6' }}>Day {dayOfMonth}</span>
                  </div>
                </div>
                <input
                  type="range"
                  min="1"
                  max="31"
                  step="1"
                  value={dayOfMonth}
                  onChange={(e) => setDayOfMonth(Number(e.target.value))}
                  className="cs-slider"
                  style={sliderTrackStyle(dayOfMonth, 1, 31)}
                />
                <div className="flex justify-between text-xs text-muted-foreground">
                  <span>Day 1</span>
                  <span>Day 31</span>
                </div>
              </div>

              {/* Input: Average Commission Rate */}
              <div className="space-y-3">
                <div className="flex items-center justify-between">
                  <label className="text-sm font-semibold" style={{ color: '#000f4d' }}>Average Commission Rate</label>
                  <div className="flex items-center gap-1 px-3 py-1.5 rounded-lg" style={{ backgroundColor: '#eef4fd' }}>
                    <span className="text-sm font-bold" style={{ color: '#294ff6' }}>{commissionRate}%</span>
                  </div>
                </div>
                <input
                  type="range"
                  min="2"
                  max="30"
                  step="0.5"
                  value={commissionRate}
                  onChange={(e) => setCommissionRate(Number(e.target.value))}
                  className="cs-slider"
                  style={sliderTrackStyle(commissionRate, 2, 30)}
                />
                <div className="flex justify-between text-xs text-muted-foreground">
                  <span>2%</span>
                  <span>30%</span>
                </div>
              </div>

              {/* Input: Agency Fee */}
              <div className="space-y-3">
                <div className="flex items-center justify-between">
                  <label className="text-sm font-semibold" style={{ color: '#000f4d' }}>Agency Fee</label>
                  <div className="flex items-center gap-1 px-3 py-1.5 rounded-lg" style={{ backgroundColor: '#eef4fd' }}>
                    <span className="text-sm font-bold" style={{ color: '#294ff6' }}>{agencyFee}%</span>
                  </div>
                </div>
                <input
                  type="range"
                  min="0"
                  max="50"
                  step="1"
                  value={agencyFee}
                  onChange={(e) => setAgencyFee(Number(e.target.value))}
                  className="cs-slider"
                  style={sliderTrackStyle(agencyFee, 0, 50)}
                />
                <div className="flex justify-between text-xs text-muted-foreground">
                  <span>0%</span>
                  <span>50%</span>
                </div>
              </div>

              {/* Input: Refund Rate */}
              <div className="space-y-3">
                <div className="flex items-center justify-between">
                  <label className="text-sm font-semibold" style={{ color: '#000f4d' }}>Refund Rate</label>
                  <div className="flex items-center gap-1 px-3 py-1.5 rounded-lg" style={{ backgroundColor: '#eef4fd' }}>
                    <span className="text-sm font-bold" style={{ color: '#294ff6' }}>{refundRate}%</span>
                  </div>
                </div>
                <input
                  type="range"
                  min="0"
                  max="20"
                  step="1"
                  value={refundRate}
                  onChange={(e) => setRefundRate(Number(e.target.value))}
                  className="cs-slider"
                  style={sliderTrackStyle(refundRate, 0, 20)}
                />
                <div className="flex justify-between text-xs text-muted-foreground">
                  <span>0%</span>
                  <span>20%</span>
                </div>
              </div>

              {/* Divider */}
              <div className="h-px" style={{ backgroundColor: '#eef4fd' }} />

              {/* Hero Result Card */}
              <div className="rounded-2xl p-6 text-center" style={{ background: 'linear-gradient(135deg, #152237 0%, #000f4d 100%)' }}>
                <div className="w-12 h-12 rounded-xl mx-auto mb-3 flex items-center justify-center" style={{ backgroundColor: 'rgba(41,79,246,0.25)' }}>
                  <DollarSign className="w-6 h-6" style={{ color: '#7a93ff' }} />
                </div>
                <p className="text-xs font-medium uppercase tracking-wide mb-1" style={{ color: '#7a93ff' }}>Projected Take Home This Month</p>
                <p className="text-4xl md:text-5xl font-bold text-white mb-1">{formatCurrency(animatedNet)}</p>
                <p className="text-sm" style={{ color: 'rgba(122,147,255,0.6)' }}>after all deductions and fees</p>
              </div>

              {/* 4 Result Cards */}
              <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
                {/* Projected Month-End GMV */}
                <div className="rounded-2xl p-5 text-center" style={{ backgroundColor: 'rgba(41,79,246,0.06)', border: '1px solid rgba(41,79,246,0.1)' }}>
                  <div className="w-10 h-10 rounded-xl mx-auto mb-3 flex items-center justify-center" style={{ backgroundColor: 'rgba(41,79,246,0.12)' }}>
                    <TrendingUp className="w-5 h-5" style={{ color: '#294ff6' }} />
                  </div>
                  <p className="text-xs font-medium uppercase tracking-wide text-muted-foreground mb-1">Projected GMV</p>
                  <p className="text-2xl font-bold" style={{ color: '#294ff6' }}>{formatWhole(animatedProjectedGMV)}</p>
                </div>

                {/* Gross Commission */}
                <div className="rounded-2xl p-5 text-center" style={{ backgroundColor: 'rgba(41,79,246,0.06)', border: '1px solid rgba(41,79,246,0.1)' }}>
                  <div className="w-10 h-10 rounded-xl mx-auto mb-3 flex items-center justify-center" style={{ backgroundColor: 'rgba(41,79,246,0.12)' }}>
                    <Percent className="w-5 h-5" style={{ color: '#294ff6' }} />
                  </div>
                  <p className="text-xs font-medium uppercase tracking-wide text-muted-foreground mb-1">Gross Commission</p>
                  <p className="text-2xl font-bold" style={{ color: '#294ff6' }}>{formatWhole(animatedGross)}</p>
                </div>

                {/* Agency Cut */}
                <div className="rounded-2xl p-5 text-center" style={{ backgroundColor: 'rgba(180,80,80,0.04)', border: '1px solid rgba(180,80,80,0.1)' }}>
                  <div className="w-10 h-10 rounded-xl mx-auto mb-3 flex items-center justify-center" style={{ backgroundColor: 'rgba(180,80,80,0.1)' }}>
                    <ShieldX className="w-5 h-5" style={{ color: '#b45050' }} />
                  </div>
                  <p className="text-xs font-medium uppercase tracking-wide text-muted-foreground mb-1">Agency Cut</p>
                  <p className="text-2xl font-bold" style={{ color: '#b45050' }}>{formatWhole(animatedAgencyCut)}</p>
                </div>

                {/* Net Take Home */}
                <div className="rounded-2xl p-5 text-center" style={{ backgroundColor: 'rgba(41,79,246,0.06)', border: '1px solid rgba(41,79,246,0.1)' }}>
                  <div className="w-10 h-10 rounded-xl mx-auto mb-3 flex items-center justify-center" style={{ backgroundColor: 'rgba(41,79,246,0.12)' }}>
                    <DollarSign className="w-5 h-5" style={{ color: '#294ff6' }} />
                  </div>
                  <p className="text-xs font-medium uppercase tracking-wide text-muted-foreground mb-1">Net Take Home</p>
                  <p className="text-2xl font-bold" style={{ color: '#000f4d' }}>{formatWhole(animatedNet)}</p>
                </div>
              </div>

              {/* Waterfall Breakdown */}
              <div className="rounded-xl p-6" style={{ backgroundColor: '#eef4fd' }}>
                <p className="text-xs font-semibold uppercase tracking-wide text-center mb-5" style={{ color: '#000f4d' }}>Earnings Waterfall Breakdown</p>
                <div className="space-y-4">
                  {waterfallSteps.map((step, i) => (
                    <div key={i}>
                      <div className="flex items-center justify-between mb-1.5">
                        <div className="flex items-center gap-2">
                          {i > 0 && <ArrowDown className="w-3 h-3 text-muted-foreground" />}
                          <span className="text-sm font-medium" style={{ color: '#000f4d' }}>{step.label}</span>
                        </div>
                        <span className="text-sm font-bold" style={{ color: step.color }}>{formatWhole(step.value)}</span>
                      </div>
                      <div className="h-3 rounded-full overflow-hidden" style={{ backgroundColor: 'rgba(255,255,255,0.8)' }}>
                        <div
                          className="h-full rounded-full transition-all duration-500 ease-out"
                          style={{
                            width: `${Math.max((step.value / maxWaterfall) * 100, 1)}%`,
                            backgroundColor: step.color,
                          }}
                        />
                      </div>
                    </div>
                  ))}
                </div>
                <div className="mt-4 pt-4 flex items-center gap-2" style={{ borderTop: '1px solid rgba(41,79,246,0.1)' }}>
                  <Calendar className="w-4 h-4" style={{ color: '#5e7bf6' }} />
                  <p className="text-sm" style={{ color: 'rgba(0,15,77,0.6)' }}>Estimated payout: ~15 days after delivery confirmation</p>
                </div>
              </div>

              {/* Earnings bar visual */}
              <div className="rounded-xl p-4" style={{ backgroundColor: '#eef4fd' }}>
                <div className="flex items-center justify-between mb-2">
                  <span className="text-xs font-medium text-muted-foreground">Net take home this month</span>
                  <span className="text-xs font-semibold" style={{ color: '#000f4d' }}>{formatCurrency(animatedNet)}</span>
                </div>
                <div className="h-3 rounded-full overflow-hidden" style={{ backgroundColor: 'rgba(255,255,255,0.8)' }}>
                  <div
                    className="h-full rounded-full transition-all duration-500 ease-out"
                    style={{
                      width: `${Math.min((netTakeHome / 5000) * 100, 100)}%`,
                      background: 'linear-gradient(90deg, #294ff6 0%, #5e7bf6 50%, #7a93ff 100%)',
                    }}
                  />
                </div>
                <div className="flex justify-between mt-1.5">
                  <span className="text-xs text-muted-foreground">{currency.symbol}0</span>
                  <span className="text-xs text-muted-foreground">{formatWhole(5000)}+</span>
                </div>
              </div>
            </CardContent>
          </Card>

          {/* Calculator Inputs Explained */}
          <Card className="border-0 shadow-lg overflow-hidden" style={{ backgroundColor: '#f8fbff' }}>
            <div className="px-8 py-6" style={{ background: 'linear-gradient(135deg, #152237 0%, #000f4d 100%)' }}>
              <div className="flex items-center gap-3">
                <div className="w-10 h-10 rounded-xl flex items-center justify-center" style={{ backgroundColor: 'rgba(41,79,246,0.2)' }}>
                  <Info className="w-5 h-5" style={{ color: '#7a93ff' }} />
                </div>
                <div>
                  <h2 className="text-xl font-bold text-white">Calculator Inputs Explained</h2>
                  <p className="text-sm" style={{ color: '#7a93ff' }}>Understand each input to get the most accurate results</p>
                </div>
              </div>
            </div>

            <CardContent className="p-8">
              <div className="overflow-x-auto">
                <table className="w-full">
                  <thead>
                    <tr style={{ borderBottom: '2px solid #eef4fd' }}>
                      <th className="text-left py-3 px-4 font-bold text-sm" style={{ color: '#000f4d' }}>Input</th>
                      <th className="text-left py-3 px-4 font-bold text-sm" style={{ color: '#000f4d' }}>Description</th>
                      <th className="text-left py-3 px-4 font-bold text-sm" style={{ color: '#000f4d' }}>Example</th>
                    </tr>
                  </thead>
                  <tbody>
                    {[
                      { name: 'GMV So Far', desc: 'Total gross merchandise value driven through your affiliate links this month', example: formatWhole(8000), required: true },
                      { name: 'Day of Month', desc: 'Current day of the month, used to project your full month earnings', example: 'Day 15', required: true },
                      { name: 'Commission Rate', desc: 'Your average commission percentage across products you promote', example: '8%', required: true },
                      { name: 'Agency Fee', desc: 'Percentage your agency takes from your commission earnings', example: '20%', required: true },
                      { name: 'Refund Rate', desc: 'Percentage of sales that get refunded, removing your commission', example: '8%', required: true },
                    ].map((row, i) => (
                      <tr key={i} className="transition-colors" style={{ borderBottom: '1px solid #eef4fd' }}>
                        <td className="py-4 px-4">
                          <div className="flex items-center gap-2">
                            <span className="font-semibold text-sm" style={{ color: '#000f4d' }}>{row.name}</span>
                            {row.required && (
                              <span className="text-xs px-2 py-0.5 rounded-full font-medium" style={{ backgroundColor: '#d8d8ff', color: '#5e7bf6' }}>Required</span>
                            )}
                          </div>
                        </td>
                        <td className="py-4 px-4 text-sm" style={{ color: 'rgba(0,15,77,0.6)' }}>{row.desc}</td>
                        <td className="py-4 px-4 font-bold text-sm" style={{ color: '#294ff6' }}>{row.example}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              <div className="mt-6 flex items-start gap-3 rounded-xl p-4" style={{ backgroundColor: '#eef4fd' }}>
                <Info className="w-4 h-4 mt-0.5 flex-shrink-0" style={{ color: '#5e7bf6' }} />
                <p className="text-sm" style={{ color: 'rgba(0,15,77,0.7)' }}>
                  TikTok Shop settlement is based on delivery confirmation, not the sale date. Payouts are typically initiated 15 days after the buyer confirms delivery, which means your actual cash arrives weeks after the sale.
                </p>
              </div>
            </CardContent>
          </Card>
        </div>
      </div>

      <style jsx>{`
        .cs-slider {
          -webkit-appearance: none;
          appearance: none;
          width: 100%;
          height: 8px;
          border-radius: 4px;
          outline: none;
          cursor: pointer;
          transition: opacity 0.15s;
        }
        .cs-slider::-webkit-slider-thumb {
          -webkit-appearance: none;
          appearance: none;
          width: 24px;
          height: 24px;
          border-radius: 50%;
          background: white;
          border: 3px solid #294ff6;
          box-shadow: 0 2px 8px rgba(41,79,246,0.3);
          cursor: pointer;
          transition: transform 0.15s, box-shadow 0.15s;
        }
        .cs-slider::-webkit-slider-thumb:hover {
          transform: scale(1.15);
          box-shadow: 0 2px 12px rgba(41,79,246,0.45);
        }
        .cs-slider::-moz-range-thumb {
          width: 24px;
          height: 24px;
          border-radius: 50%;
          background: white;
          border: 3px solid #294ff6;
          box-shadow: 0 2px 8px rgba(41,79,246,0.3);
          cursor: pointer;
        }
      `}</style>
    </div>
  );
}
