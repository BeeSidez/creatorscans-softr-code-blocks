                    { label: 'Full Refund', desc: 'If a buyer returns the product for a full refund, 100% of the commission for that sale is clawed back. The sale is treated as if it never happened.', avoid: true },
                    { label: 'Partial Refund', desc: 'If a buyer receives a partial refund, the commission is reduced proportionally. For example, a 50% refund on a sale results in a 50% commission reduction.', avoid: false },
