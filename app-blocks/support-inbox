function RequestRow({ record, active, onClick }) {
  const type = getRequestType(record.fields.request);
  const iconUrl = record.fields.icon || type?.icon;
  const title = type?.short || "Request";
  const preview = truncate(record.fields.notes || "", 60);
  const time = relativeTime(
    record.fields.lastUpdatedAt || record.fields.createdAt || record.createdAt
  );
  const status = record.fields.status;
  const hasReply = !!record.fields.response;

  return (
    <button
      type="button"
      onClick={onClick}
      className="w-full text-left border-b transition-colors focus:outline-none"
      style={{
        background: active ? CS.light2 : "transparent",
