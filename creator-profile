  tagline: "v2Gu1",
  tiktokUsername: "uZ8z0",
  tiktokProfileUrl: "f2AHE",
  followers: "wMXX0",
  pronouns: "W933n",
  gender: "ZrMCm",
  birthday: "A79E9",
  generation: "UiS1H",
  age: "aNbbk",
  city: "z4TF1",
  regionalAccent: "TV7Nz",
  firstLanguage: "3hJpt",
  ethnicBackground: "iXpQB",
  heritage: "FzvXF",
  localDialect: "aWNgr",
  jobTitle: "6aChZ",
  industry: "aDyIX",
  position: "1kULp",
  careerStage: "SCLTv",
  income: "iwraT",
  myGoal: "uNdfV",
  lookingFor: "VzOte",
  shopBound: "bTOzJ",
