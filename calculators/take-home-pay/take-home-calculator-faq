import { useState } from 'react';
import { Plus, Minus } from 'lucide-react';

const faqs = [
  {
    question: 'How much do TikTok Shop affiliates actually take home?',
    answer: 'Most affiliates take home 60-75% of their gross commission after refunds and agency fees. For example, if you earn \u00a31,000 in gross commission, expect \u00a3600-\u00a3750 in your pocket after an 8% refund rate and 20% agency cut. Your actual take home depends heavily on your refund rate and whether you use an agency.'
  },
  {
    question: 'How does TikTok Shop settlement timing work?',
    answer: 'TikTok does not pay you when the sale happens. Settlement begins 15 days after the buyer confirms delivery, not after the purchase date. Since delivery can take 3-7 days and the return window adds another 7-14 days, you may wait 3-5 weeks from the sale date to receive your payout.'
  },
  {
    question: 'How do refunds affect my take home pay?',
    answer: 'Refunds directly reduce your commission. A full refund removes 100% of the commission for that sale. A partial refund reduces your commission proportionally. Average refund rates on TikTok Shop range from 5-10%, but some categories like clothing can see 15-20% return rates.'
  },
  {
    question: 'How much does an agency take from my TikTok Shop earnings?',
    answer: 'Most TikTok Shop agencies take 15-30% of your commission earnings. Some agencies take their cut before refunds are deducted, which costs you more. Always clarify whether the agency fee is calculated on gross or net commission. A 20% agency fee on \u00a31,000 gross commission costs you \u00a3200.'
  },
  {
    question: 'How does this calculator project my month-end earnings?',
    answer: 'The calculator divides your GMV so far by the current day of the month to get your daily average. It then multiplies this by the total days in the month to project your full month GMV. This assumes your daily earning rate stays consistent for the rest of the month.'
  },
  {
    question: 'When will my TikTok Shop payout actually arrive?',
    answer: 'Payouts are initiated approximately 15 days after the buyer confirms delivery. After initiation, the transfer to your bank account or PayPal takes an additional 1-3 business days. For sales made at the start of a month, expect the payout around the middle of the following month.'
  },
  {
    question: 'Does TikTok take a cut from affiliates directly?',
    answer: 'No, TikTok does not take a separate fee from affiliates. TikTok charges the seller a platform fee (typically 5-8%), and the seller sets the affiliate commission rate from their remaining margin. The commission rate you see in the affiliate marketplace is what you actually earn per sale.'
  },
  {
    question: 'How can I increase my net take home pay on TikTok Shop?',
    answer: 'Focus on three levers: increase your commission rate by negotiating directly with sellers, reduce your refund rate by promoting quality products you have personally tested, and reduce or eliminate your agency fee. Going from a 20% agency to 0% instantly increases your take home by 25%. Promoting low-return categories like beauty and accessories also helps significantly.'
  }
];

export default function Block() {
  const [openIndex, setOpenIndex] = useState(null);

  const toggleFaq = (index) => {
    setOpenIndex(openIndex === index ? null : index);
  };

  const highlightValues = (text) => {
    const parts = text.split(/(\u00a3[0-9,]+\.?[0-9]*|\u00a3[0-9,]+|[0-9]+-[0-9]+%|[0-9]+%|[0-9]+-[0-9]+ days|[0-9]+-[0-9]+ weeks|[0-9]+-[0-9]+ business days|[0-9]+K\+|[0-9]+-[0-9]+x|[0-9]+x|15 days|25%)/g);
    return parts.map((part, i) => {
      if (part.match(/(\u00a3[0-9,]+\.?[0-9]*|\u00a3[0-9,]+|[0-9]+-[0-9]+%|[0-9]+%|[0-9]+-[0-9]+ days|[0-9]+-[0-9]+ weeks|[0-9]+-[0-9]+ business days|[0-9]+K\+|[0-9]+-[0-9]+x|[0-9]+x|15 days|25%)/)) {
        return <span key={i} className="font-semibold" style={{ color: '#294ff6' }}>{part}</span>;
      }
      return part;
    });
  };

  return (
    <div style={{ background: 'linear-gradient(180deg, #fafbff 0%, #f8fbff 50%, #fafbff 100%)' }}>
      <div className="container py-16">
        <div className="content max-w-4xl mx-auto">
          {/* Section header */}
          <div className="text-center mb-10">
            <div className="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-4" style={{ backgroundColor: 'rgba(41,79,246,0.08)', border: '1px solid rgba(41,79,246,0.12)' }}>
              <span className="text-sm font-semibold" style={{ color: '#294ff6' }}>FAQ</span>
            </div>
            <h2 className="text-3xl md:text-4xl font-bold mb-3" style={{ color: '#000f4d' }}>
              Frequently Asked Questions
            </h2>
            <p className="text-muted-foreground max-w-2xl mx-auto">
              Everything you need to know about TikTok Shop take home pay, settlement timing, and maximizing your net earnings
            </p>
          </div>

          {/* FAQ Items */}
          <div className="space-y-3">
            {faqs.map((faq, index) => {
              const isOpen = openIndex === index;

              return (
                <div
                  key={index}
                  className="rounded-xl overflow-hidden transition-all duration-300 shadow-sm"
                  style={{
                    backgroundColor: '#f8fbff',
                    border: isOpen ? '1px solid rgba(41,79,246,0.2)' : '1px solid transparent',
                  }}
                >
                  <button
                    onClick={() => toggleFaq(index)}
                    className="w-full px-6 py-5 flex items-center justify-between gap-4 text-left transition-colors"
                    aria-expanded={isOpen}
                  >
                    <div className="flex items-center gap-4">
                      {/* Left accent bar */}
                      <div
                        className="w-1 h-6 rounded-full transition-all duration-300 flex-shrink-0"
                        style={{
                          backgroundColor: isOpen ? '#294ff6' : '#eef4fd',
                        }}
                      />
                      <span className="font-semibold text-base md:text-lg leading-relaxed" style={{ color: '#000f4d' }}>
                        {faq.question}
                      </span>
                    </div>
                    <div
                      className="flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center transition-all duration-300"
                      style={{
                        backgroundColor: isOpen ? 'rgba(41,79,246,0.12)' : '#eef4fd',
                      }}
                    >
                      {isOpen ? (
                        <Minus className="w-4 h-4" style={{ color: '#294ff6' }} />
                      ) : (
                        <Plus className="w-4 h-4" style={{ color: '#7a93ff' }} />
                      )}
                    </div>
                  </button>

                  <div
                    className="overflow-hidden transition-all duration-300 ease-in-out"
                    style={{
                      maxHeight: isOpen ? '500px' : '0',
                      opacity: isOpen ? 1 : 0,
                    }}
                  >
                    <div className="px-6 pb-6 pt-0 ml-5">
                      <div className="pl-4" style={{ borderLeft: '2px solid #eef4fd' }}>
                        <p className="text-foreground leading-relaxed">
                          {highlightValues(faq.answer)}
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  );
}
