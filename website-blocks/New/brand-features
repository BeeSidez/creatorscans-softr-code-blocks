// ─── Tab pill ────────────────────────────────────────────────────
function TabPill({ active, onClick, label, accent, dot }) {
  return (
    <button
      onClick={onClick}
      className="relative transition-all duration-300 rounded-full font-bold uppercase tracking-[2px]"
      style={{
        padding: "14px 28px",
        fontSize: 12,
        border: active ? `1px solid ${accent}` : "1px solid rgba(255,255,255,0.12)",
        background: active ? `${accent}22` : "rgba(255,255,255,0.03)",
        color: active ? accent : "rgba(255,255,255,0.55)",
      }}
    >
      <span className="inline-flex items-center gap-2">
        <span className="rounded-full" style={{ width: 6, height: 6, background: active ? accent : "rgba(255,255,255,0.3)", boxShadow: active ? `0 0 10px ${accent}` : "none" }} />
        {label}
      </span>
    </button>
  );
}

