                        <p className="text-sm font-semibold mb-0.5" style={{ color: '#000f4d' }}>{item.label}</p>
                        <p className="text-sm leading-relaxed" style={{ color: item.avoid ? 'rgba(0,15,77,0.6)' : 'rgba(0,15,77,0.7)' }}>
