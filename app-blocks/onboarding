  // Fetch the available Memberships rows (read-only, populates the
  // dropdown of tier options the user can link themselves to).
  const { data: membershipData } = useLinkedRecords({
    select: membershipSelect,
    field: "memberships",
    count: 100,
  });
  const allMemberships = useMemo(
    () => membershipData?.pages.flatMap((p) => p.items) || [],
    [membershipData],
  );

  // Local form state — initialised from the user record once loaded
  const [form, setForm] = useState({
    tiktokUsername: "",
    track: [],
    membershipsByTrack: {}, // { shop: "rec123", live: "rec456", organic: "rec789" }
    age: "",
    pronouns: "",
    gender: "",
    birthday: "",
    city: "",
    regionalAccent: "",
    heritage: "",
    firstLanguage: "",
    localDialect: false,
    jobTitle: "",
    industry: [],
    position: [],
    careerStage: [],
    income: "",
    lookingFor: [],
    myGoal: "",
  });

  // Hydrate form from the loaded user record (one-time)
  useMemo(() => {
    if (!data?.fields) return;
    setForm((prev) => ({
      ...prev,
      tiktokUsername: data.fields.tiktokUsername || prev.tiktokUsername,
      age: data.fields.age?.id || prev.age,
      pronouns: data.fields.pronouns?.id || prev.pronouns,
      gender: data.fields.gender?.id || prev.gender,
      birthday: data.fields.birthday || prev.birthday,
      city: data.fields.city || prev.city,
      regionalAccent: data.fields.regionalAccent?.id || prev.regionalAccent,
      heritage: data.fields.heritage || prev.heritage,
      firstLanguage: data.fields.firstLanguage || prev.firstLanguage,
      localDialect: data.fields.localDialect ?? prev.localDialect,
      jobTitle: data.fields.jobTitle || prev.jobTitle,
      industry: Array.isArray(data.fields.industry)
        ? data.fields.industry.map((i) => i.id)
        : prev.industry,
      position: Array.isArray(data.fields.position)
        ? data.fields.position.map((i) => i.id)
        : prev.position,
      careerStage: Array.isArray(data.fields.careerStage)
        ? data.fields.careerStage.map((i) => i.id)
        : prev.careerStage,
      income: data.fields.income?.id || prev.income,
      lookingFor: Array.isArray(data.fields.lookingFor)
        ? data.fields.lookingFor.map((i) => i.id)
        : prev.lookingFor,
      myGoal: data.fields.myGoal || prev.myGoal,
    }));
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [data?.id]);

  const updateRecord = useRecordUpdate({
    fields: select,
    async onSuccess() {
      await refetch();
    },
    onError(err) {
      toast.error("Save failed", { description: err.message });
      setSaving(false);
    },
  });

  const persistFields = async (fields) => {
    setSaving(true);
    try {
      await updateRecord.mutateAsync({ recordId: data.id, fields });
      setSaving(false);
    } catch (e) {
      // onError handler already toasted
    }
  };

  const set = (key, value) => setForm((f) => ({ ...f, [key]: value }));

  const toggleInArray = (key, id) => {
    setForm((f) => {
      const arr = f[key] || [];
      return {
        ...f,
        [key]: arr.includes(id) ? arr.filter((x) => x !== id) : [...arr, id],
      };
    });
  };

  const goNext = () => setStepIdx((i) => Math.min(i + 1, STEPS.length - 1));
  const goBack = () => setStepIdx((i) => Math.max(i - 1, 0));

  // ─── Per-step continue handlers ────────────────────────────────
  const continueWelcome = () => goNext();

  const continueTiktok = async () => {
    if (!form.tiktokUsername.trim()) return;
    const handle = form.tiktokUsername.trim().replace(/^@/, "");
    await persistFields({ uZ8z0: handle });
    setForm((f) => ({ ...f, tiktokUsername: handle }));
    goNext();
  };

  const continueTrack = () => {
    // Track picks are local-state only — no User.Track write.
    // Memberships (set in the next step) are the source of truth.
    if (form.track.length === 0) return;
    goNext();
  };

  const continueCadence = async () => {
    const selectedKeys = TRACK_OPTIONS.filter((t) => form.track.includes(t.key)).map((t) => t.key);
    const allPicked = selectedKeys.every((k) => !!form.membershipsByTrack[k]);
    if (!allPicked) return;
    const ids = selectedKeys
      .map((k) => form.membershipsByTrack[k])
      .filter(Boolean)
      .map((id) => ({ id }));
    await persistFields({ PxOWN: ids });
    goNext();
  };

  const continueAbout = async () => {
    if (!form.age || !form.gender) return;
    const updates = {
      aNbbk: toIdLabel(AGE_OPTIONS, form.age),
      ZrMCm: toIdLabel(GENDER_OPTIONS, form.gender),
    };
    if (form.pronouns) updates.W933n = toIdLabel(PRONOUNS_OPTIONS, form.pronouns);
    if (form.birthday) updates.A79E9 = form.birthday;
    await persistFields(updates);
    goNext();
  };

  const continueWhere = async () => {
    const updates = {};
    if (form.city) updates.z4TF1 = form.city;
    if (form.regionalAccent) updates.TV7Nz = toIdLabel(REGIONAL_ACCENT_OPTIONS, form.regionalAccent);
    if (form.heritage) updates.FzvXF = form.heritage;
    if (form.firstLanguage) updates["3hJpt"] = form.firstLanguage;
    updates.aWNgr = !!form.localDialect;
    await persistFields(updates);
    goNext();
  };

  const continueCareer = async () => {
    const updates = {};
    if (form.jobTitle) updates["6aChZ"] = form.jobTitle;
    if (form.industry.length) updates.aDyIX = toIdLabelArray(INDUSTRY_OPTIONS, form.industry);
    if (form.position.length) updates["1kULp"] = toIdLabelArray(POSITION_OPTIONS, form.position);
    if (form.careerStage.length) updates.SCLTv = toIdLabelArray(CAREER_STAGE_OPTIONS, form.careerStage);
    if (form.income) updates.iwraT = toIdLabel(INCOME_OPTIONS, form.income);
    await persistFields(updates);
    goNext();
  };

  const continueWhy = async () => {
    const updates = {};
    if (form.lookingFor.length) updates.VzOte = toIdLabelArray(LOOKING_FOR_OPTIONS, form.lookingFor);
    if (form.myGoal) updates.uNdfV = form.myGoal;
    await persistFields(updates);
    goNext();
  };

  const skipStep = () => goNext();

  const handleConnectTikTok = async () => {
    setSaving(true);

    // Generate CSRF state, store in sessionStorage to match dashboard block
    const state = generateOAuthState();
    try {
      sessionStorage.setItem("cs_tiktok_oauth_state", state);
    } catch (e) {
      // sessionStorage might be blocked; proceed anyway
    }

    // Redirect to TikTok OAuth with our state
    const url = `${TIKTOK_OAUTH_BASE}&state=${state}`;
    window.location.href = url;
  };

  // ─── Render guards ─────────────────────────────────────────────
  if (status === "pending") {
    return (
      <div className="container py-12">
        <div className="content flex items-center justify-center min-h-[400px]">
          <div className="text-muted-foreground">Loading your onboarding…</div>
        </div>
      </div>
    );
  }

  if (status === "error" || !data) {
    return (
      <div className="container py-12">
        <div className="content flex items-center justify-center min-h-[400px]">
          <div className="text-destructive">
            We couldn't load your account. Refresh and try again.
          </div>
        </div>
      </div>
    );
