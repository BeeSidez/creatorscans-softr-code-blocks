    { niche: 'Finance/Investing', range: '2-3x average', barPct: 100, color: '#294ff6' },
    { niche: 'Technology/SaaS', range: '1.5-2.5x average', barPct: 83, color: '#4466f8' },
    { niche: 'Health/Wellness', range: '1.5-2x average', barPct: 66, color: '#5e7bf6' },
    { niche: 'Business/B2B', range: '1.5-2x average', barPct: 66, color: '#5e7bf6' },
    { niche: 'Beauty/Fashion', range: '1x average', barPct: 40, color: '#7a93ff' },
    { niche: 'Fitness', range: '1x average', barPct: 40, color: '#7a93ff' },
