                  <h3 className="font-bold text-white text-base">{currency.code} to TikTok Diamonds</h3>
                  <p className="text-xs" style={{ color: '#7a93ff' }}>How many diamonds do you need to earn a specific amount?</p>
                </div>
                <CardContent className="p-6">
                  <div className="space-y-0">
                    {reverseConversions.map((row, index) => (
                      <div key={index}>
                        <div className="flex items-center justify-between py-3 px-3">
                          <h4 className="font-semibold text-sm" style={{ color: '#000f4d' }}>
                            {row.label}
                          </h4>
                          <span className="font-bold text-sm" style={{ color: '#294ff6' }}>{row.diamonds}</span>
                        </div>
                        {index < reverseConversions.length - 1 && (
                          <div className="h-px mx-3" style={{ backgroundColor: '#eef4fd' }} />
                        )}
                      </div>
                    ))}
                  </div>

                  <div className="mt-4 rounded-xl p-4 flex items-start gap-3" style={{ backgroundColor: '#eef4fd' }}>
                    <div className="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style={{ backgroundColor: '#294ff6' }}>
                      <span className="text-white text-xs font-bold">i</span>
                    </div>
                    <p className="text-xs" style={{ color: 'rgba(0,15,77,0.7)' }}>
                      Formula: Diamonds needed = Amount in {currency.code} / {formatValue(0.0036)}. You need at least 10,000 diamonds ({formatValue(36)}) to make a withdrawal from TikTok.
                    </p>
                  </div>
                </CardContent>
              </Card>
            </div>
          </div>

          <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">

            {/* Card 1: Understanding TikTok Diamonds */}
            <Card className="border-0 shadow-sm overflow-hidden" style={{ backgroundColor: '#f8fbff' }}>
              <div className="px-6 py-5" style={{ background: 'linear-gradient(135deg, #152237 0%, #000f4d 100%)' }}>
                <div className="flex items-center gap-3">
                  <img
                    src="https://res.cloudinary.com/dmrekfwpj/image/upload/v1770810149/59_fo4vnl.png"
                    alt="Diamond"
                    className="w-10 h-10"
                  />
                  <div>
                    <h3 className="font-bold text-white text-base">Understanding TikTok Diamonds</h3>
                    <p className="text-xs" style={{ color: '#7a93ff' }}>How the diamond economy works</p>
                  </div>
                </div>
              </div>
              <CardContent className="p-6">
                <div className="space-y-3">
                  {keyFacts.map((fact, index) => (
                    <div key={index} className="flex items-start justify-between gap-4 py-2.5" style={{ borderBottom: '1px solid #eef4fd' }}>
                      <span className="text-sm font-semibold" style={{ color: '#000f4d' }}>{fact.label}</span>
                      <span
                        className="text-sm text-right"
                        style={{
                          color: fact.highlight ? '#294ff6' : 'rgba(0,15,77,0.6)',
                          fontWeight: fact.highlight ? '700' : '400',
                        }}
                      >
                        {fact.value}
                      </span>
                    </div>
                  ))}
                </div>
              </CardContent>
            </Card>

            {/* Card 2: Diamond Conversion Table */}
            <Card className="border-0 shadow-sm overflow-hidden" style={{ backgroundColor: '#f8fbff' }}>
              <div className="px-6 py-5" style={{ background: 'linear-gradient(135deg, #152237 0%, #000f4d 100%)' }}>
                <div className="flex items-center gap-3">
                  <img
                    src="https://res.cloudinary.com/dmrekfwpj/image/upload/v1770810149/58_nztnfj.png"
                    alt="Table"
                    className="w-10 h-10"
                  />
                  <div>
                    <h3 className="font-bold text-white text-base">Diamond Conversion Table</h3>
                    <p className="text-xs" style={{ color: '#7a93ff' }}>Quick reference at £0.0036 per diamond</p>
                  </div>
                </div>
              </div>
              <CardContent className="p-6">
                <div className="space-y-3">
                  {conversionData.map((row, index) => (
                    <div key={index}>
                      <div className="flex justify-between items-center mb-1.5">
                        <div className="flex items-center gap-2">
                          <span className="font-semibold text-sm" style={{ color: '#000f4d' }}>
                            {row.diamonds} diamonds
                          </span>
                          {row.isMinimum && (
                            <span className="text-xs px-2 py-0.5 rounded-full font-medium" style={{ backgroundColor: '#d8d8ff', color: '#5e7bf6' }}>
                              min. withdrawal
                            </span>
                          )}
                        </div>
                        <span className="font-bold text-sm" style={{ color: '#294ff6' }}>{row.gbp}</span>
                      </div>
                      <div className="h-1.5 rounded-full" style={{ backgroundColor: '#eef4fd' }}>
                        <div
                          className="h-full rounded-full"
                          style={{
                            width: `${row.pct}%`,
                            background: row.isMinimum
                              ? 'linear-gradient(90deg, #294ff6, #5e7bf6)'
                              : 'linear-gradient(90deg, #7a93ff, #879cf7)',
                          }}
                        />
                      </div>
                    </div>
                  ))}
                </div>
              </CardContent>
            </Card>

            {/* Card 3: Maximize Diamond Earnings */}
            <Card className="border-0 shadow-sm overflow-hidden" style={{ backgroundColor: '#f8fbff' }}>
              <div className="px-6 py-5" style={{ background: 'linear-gradient(135deg, #152237 0%, #000f4d 100%)' }}>
                <div className="flex items-center gap-3">
                  <img
                    src="https://res.cloudinary.com/dmrekfwpj/image/upload/v1770810149/56_wpngbq.png"
                    alt="Growth"
                    className="w-10 h-10"
                  />
                  <div>
                    <h3 className="font-bold text-white text-base">Maximize Diamond Earnings</h3>
                    <p className="text-xs" style={{ color: '#7a93ff' }}>8 proven strategies for LIVE streams</p>
                  </div>
                </div>
              </div>
              <CardContent className="p-6">
                <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  {strategies.map((strategy, index) => (
                    <div
                      key={index}
                      className="rounded-xl p-4"
                      style={{ backgroundColor: index % 2 === 0 ? 'rgba(41,79,246,0.04)' : 'rgba(94,123,246,0.04)', border: '1px solid rgba(41,79,246,0.06)' }}
                    >
                      <div className="flex gap-3">
                        <div className="w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0" style={{ backgroundColor: index < 4 ? '#294ff6' : '#7a93ff' }}>
                          <span className="text-white text-xs font-bold">{index + 1}</span>
                        </div>
                        <p className="text-sm leading-relaxed" style={{ color: '#000f4d' }}>
                          {strategy}
