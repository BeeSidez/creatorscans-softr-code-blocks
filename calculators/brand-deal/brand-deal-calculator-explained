    { tier: 'Mid-tier (50K-100K)', low: 1970, high: 3940, barPct: 40, featured: true },
    { tier: 'Macro (100K-500K)', low: 3940, high: 11810, barPct: 65, featured: true },
    { tier: 'Mega (500K-1M)', low: 11810, high: 27560, barPct: 85 },
