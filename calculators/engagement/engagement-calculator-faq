import { useState } from 'react';
import { Plus, Minus } from 'lucide-react';

const faqs = [
  {
    question: 'What is a good engagement rate on TikTok in 2026?',
    answer: 'A good engagement rate is 5-8%. Excellent is 8%+. Average is 3-5%. Below 3% is considered below average. Rates naturally decrease as follower count grows, so compare against your own tier.'
  },
  {
    question: 'How do you calculate TikTok engagement rate?',
    answer: 'The standard formula is: (Likes + Comments + Shares) / Followers x 100. Use averages from your last 10-20 posts for accuracy. This is the industry standard formula brands use.'
  },
  {
    question: 'Why is engagement rate important for creators?',
    answer: 'Engagement rate is the top metric brands evaluate for partnerships. A creator with 50K followers and 8% engagement is more valuable than one with 500K followers and 1% engagement. It directly impacts brand deal rates.'
  },
  {
    question: 'What engagement rate do brands look for?',
    answer: 'Most brands want 5%+ engagement rate. Premium brands and exclusive campaigns typically require 8%+. Some brands accept 3-5% for large accounts with specific audience demographics.'
  },
  {
    question: 'Why does engagement rate decrease as followers increase?',
    answer: 'As accounts grow, a larger percentage of followers become passive. Nano creators (1K-5K) average 8-15%, while macro creators (500K+) average 2-4%. This is normal and expected.'
  },
  {
    question: 'How do I improve my TikTok engagement rate?',
    answer: 'Hook viewers in the first 1-2 seconds, ask questions to encourage comments, post during peak hours, respond to comments quickly, create duet/stitch-worthy content, and post consistently.'
  },
  {
    question: 'Does engagement rate affect the TikTok algorithm?',
    answer: 'Yes. Higher engagement signals quality content, leading to more distribution. Comments and shares carry the most weight. Watch time and completion rate are also critical factors.'
  },
  {
    question: 'What is the average TikTok engagement rate by follower count?',
    answer: 'Nano (1K-5K): 8-15%, Micro (5K-50K): 5-8%, Mid-tier (50K-500K): 3-5%, Macro (500K+): 2-4%. These are 2026 industry benchmarks.'
  },
