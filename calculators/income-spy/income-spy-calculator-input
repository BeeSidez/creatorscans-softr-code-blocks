                  <div className="flex justify-center py-1">
                    <ArrowDown className="w-4 h-4" style={{ color: '#dc2626' }} />
                  </div>
                  {/* Step 3: After Refunds */}
                  <div className="flex items-center gap-4">
                    <div className="w-full rounded-lg p-3" style={{ backgroundColor: 'rgba(220,38,38,0.04)', border: '1px solid rgba(220,38,38,0.1)' }}>
                      <div className="flex justify-between items-center">
                        <span className="text-sm font-medium" style={{ color: '#000f4d' }}>After Refunds (-{refundRate}%)</span>
                        <span className="text-sm font-bold" style={{ color: '#dc2626' }}>-{formatWhole(grossCommission - afterRefunds)}</span>
                      </div>
