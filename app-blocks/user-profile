  { id: "7c18b135-14c3-4495-b16e-95b72d3e0cbc", label: "18-24" },
  { id: "5b2a810b-00f7-4858-88db-6d0c423d646b", label: "25-34" },
  { id: "52f19f78-b5fb-40ce-be37-6328d3cd01c8", label: "35-44" },
  { id: "78b01971-c8c5-40fe-8d82-f28f87d2b3bb", label: "45-54" },
  { id: "eadfa9ad-457b-438a-9ffd-c49141be5aa8", label: "55+" },
];

const PRONOUNS_OPTIONS = [
  { id: "7c923ac9-29b6-4f43-9bdd-26c41f3d4a87", label: "She" },
  { id: "4561af4c-a1db-4d5b-8f8c-dbf4f138cc58", label: "Her" },
  { id: "3bad761c-42fa-48f4-ac62-6dbfd01c4871", label: "He" },
  { id: "6ea6a342-d2a1-43cc-ba97-0623e98b4310", label: "Him" },
