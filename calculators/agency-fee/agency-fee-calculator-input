import { useState, useEffect, useRef } from 'react';
import { Card, CardContent } from '@/components/ui/card';
import { Calculator, TrendingDown, TrendingUp, Info, DollarSign, PieChart, Calendar } from 'lucide-react';

const currencies = [
  { code: 'GBP', symbol: '\u00a3', rate: 1 },
  { code: 'USD', symbol: '$', rate: 1.27 },
  { code: 'EUR', symbol: '\u20ac', rate: 1.17 },
];

export default function Block() {
  const [gmv, setGmv] = useState(25000);
  const [commissionRate, setCommissionRate] = useState(10);
  const [agencyFee, setAgencyFee] = useState(20);
  const [currencyIdx, setCurrencyIdx] = useState(0);
  const [animAgencyMonthly, setAnimAgencyMonthly] = useState(0);
  const [animCreatorMonthly, setAnimCreatorMonthly] = useState(0);
  const [animAgencyAnnual, setAnimAgencyAnnual] = useState(0);
  const [animCreatorAnnual, setAnimCreatorAnnual] = useState(0);
  const [animGrossMonthly, setAnimGrossMonthly] = useState(0);
  const animFrameRef = useRef(null);

  const currency = currencies[currencyIdx];

  const grossCommission = gmv * (commissionRate / 100);
  const agencyTakeMonthly = grossCommission * (agencyFee / 100);
  const creatorTakeMonthly = grossCommission - agencyTakeMonthly;
  const agencyTakeAnnual = agencyTakeMonthly * 12;
  const creatorTakeAnnual = creatorTakeMonthly * 12;

  useEffect(() => {
    const startAM = animAgencyMonthly;
    const startCM = animCreatorMonthly;
    const startAA = animAgencyAnnual;
    const startCA = animCreatorAnnual;
    const startGM = animGrossMonthly;
    const duration = 400;
    const startTime = Date.now();

    const animate = () => {
      const elapsed = Date.now() - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const ease = 1 - Math.pow(1 - progress, 3);

      setAnimAgencyMonthly(startAM + (agencyTakeMonthly - startAM) * ease);
      setAnimCreatorMonthly(startCM + (creatorTakeMonthly - startCM) * ease);
      setAnimAgencyAnnual(startAA + (agencyTakeAnnual - startAA) * ease);
      setAnimCreatorAnnual(startCA + (creatorTakeAnnual - startCA) * ease);
      setAnimGrossMonthly(startGM + (grossCommission - startGM) * ease);

      if (progress < 1) {
        animFrameRef.current = requestAnimationFrame(animate);
      }
    };

    if (animFrameRef.current) cancelAnimationFrame(animFrameRef.current);
    animFrameRef.current = requestAnimationFrame(animate);

    return () => {
      if (animFrameRef.current) cancelAnimationFrame(animFrameRef.current);
    };
  }, [agencyTakeMonthly, creatorTakeMonthly, agencyTakeAnnual, creatorTakeAnnual, grossCommission]);

  const convert = (val) => val * currency.rate;

  const formatCurrency = (val) => {
    const converted = convert(val);
    if (currency.rate >= 50) {
      return currency.symbol + Math.round(converted).toLocaleString('en-GB');
    }
    return currency.symbol + converted.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  };

  const formatWhole = (val) => {
    const converted = val * currency.rate;
    return currency.symbol + Math.round(converted).toLocaleString('en-GB');
  };

  const sliderTrackStyle = (value, min, max) => {
    const pct = ((value - min) / (max - min)) * 100;
    return {
      background: `linear-gradient(to right, #294ff6 0%, #5e7bf6 ${pct}%, #eef4fd ${pct}%, #eef4fd 100%)`,
    };
  };

  const agencyPct = agencyFee;
  const creatorPct = 100 - agencyFee;

  return (
    <div style={{ background: 'linear-gradient(180deg, #fafbff 0%, #f8fbff 50%, #fafbff 100%)' }}>
      <div className="container py-16">
        <div className="content max-w-5xl mx-auto space-y-8">

          {/* Calculator Card */}
          <Card className="border-0 shadow-lg overflow-hidden" style={{ backgroundColor: '#f8fbff' }}>
            {/* Card Header */}
            <div className="px-8 py-6" style={{ background: 'linear-gradient(135deg, #152237 0%, #000f4d 100%)' }}>
              <div className="flex items-center justify-between flex-wrap gap-4">
                <div className="flex items-center gap-3">
                  <div className="w-10 h-10 rounded-xl flex items-center justify-center" style={{ backgroundColor: 'rgba(41,79,246,0.2)' }}>
                    <Calculator className="w-5 h-5" style={{ color: '#7a93ff' }} />
                  </div>
                  <div>
                    <h2 className="text-xl font-bold text-white">Agency Fee Calculator</h2>
                    <p className="text-sm" style={{ color: '#7a93ff' }}>See exactly how much your agency takes from your earnings</p>
                  </div>
                </div>

                {/* Currency Selector */}
                <select
                  value={currencyIdx}
                  onChange={(e) => setCurrencyIdx(Number(e.target.value))}
                  className="px-3 py-2 rounded-lg text-sm font-medium cursor-pointer"
                  style={{ backgroundColor: 'rgba(41,79,246,0.2)', border: '1px solid rgba(122,147,255,0.3)', color: 'white', outline: 'none' }}
                >
                  {currencies.map((c, idx) => (
                    <option key={c.code} value={idx} style={{ backgroundColor: '#152237', color: 'white' }}>
                      {c.symbol} {c.code}
                    </option>
                  ))}
                </select>
              </div>
            </div>

            <CardContent className="p-8 space-y-8">
              {/* Input: Monthly GMV */}
              <div className="space-y-3">
                <div className="flex items-center justify-between">
                  <label className="text-sm font-semibold" style={{ color: '#000f4d' }}>Monthly GMV</label>
                  <div className="flex items-center gap-1 px-3 py-1.5 rounded-lg" style={{ backgroundColor: '#eef4fd' }}>
                    <span className="text-sm font-bold" style={{ color: '#294ff6' }}>{formatWhole(gmv)}</span>
                  </div>
                </div>
                <input
                  type="range"
                  min="1000"
                  max="500000"
                  step="1000"
                  value={gmv}
                  onChange={(e) => setGmv(Number(e.target.value))}
                  className="cs-slider"
                  style={sliderTrackStyle(gmv, 1000, 500000)}
                />
                <div className="flex justify-between text-xs text-muted-foreground">
                  <span>{formatWhole(1000)}</span>
                  <span>{formatWhole(500000)}</span>
                </div>
              </div>

              {/* Input: Commission Rate */}
              <div className="space-y-3">
                <div className="flex items-center justify-between">
                  <label className="text-sm font-semibold" style={{ color: '#000f4d' }}>Commission Rate</label>
                  <div className="flex items-center gap-1 px-3 py-1.5 rounded-lg" style={{ backgroundColor: '#eef4fd' }}>
                    <span className="text-sm font-bold" style={{ color: '#294ff6' }}>{commissionRate}%</span>
                  </div>
                </div>
                <input
                  type="range"
                  min="2"
                  max="30"
                  step="0.5"
                  value={commissionRate}
                  onChange={(e) => setCommissionRate(Number(e.target.value))}
                  className="cs-slider"
                  style={sliderTrackStyle(commissionRate, 2, 30)}
                />
                <div className="flex justify-between text-xs text-muted-foreground">
                  <span>2%</span>
                  <span>30%</span>
                </div>
              </div>

              {/* Input: Agency Fee */}
              <div className="space-y-3">
                <div className="flex items-center justify-between">
                  <label className="text-sm font-semibold" style={{ color: '#000f4d' }}>Agency Fee</label>
                  <div className="flex items-center gap-1 px-3 py-1.5 rounded-lg" style={{ backgroundColor: '#eef4fd' }}>
                    <span className="text-sm font-bold" style={{ color: '#294ff6' }}>{agencyFee}%</span>
                  </div>
                </div>
                <input
                  type="range"
                  min="0"
                  max="50"
                  step="1"
                  value={agencyFee}
                  onChange={(e) => setAgencyFee(Number(e.target.value))}
                  className="cs-slider"
                  style={sliderTrackStyle(agencyFee, 0, 50)}
                />
                <div className="flex justify-between text-xs text-muted-foreground">
                  <span>0%</span>
                  <span>50%</span>
                </div>
              </div>

              {/* Divider */}
              <div className="h-px" style={{ backgroundColor: '#eef4fd' }} />

              {/* Hero Result Card */}
              <div className="rounded-2xl p-6 text-center" style={{ background: 'linear-gradient(135deg, #152237 0%, #000f4d 100%)' }}>
                <div className="w-12 h-12 rounded-xl mx-auto mb-3 flex items-center justify-center" style={{ backgroundColor: 'rgba(41,79,246,0.25)' }}>
                  <TrendingDown className="w-6 h-6" style={{ color: '#7a93ff' }} />
                </div>
                <p className="text-xs font-medium uppercase tracking-wide mb-1" style={{ color: '#7a93ff' }}>Your Agency Takes</p>
                <p className="text-4xl md:text-5xl font-bold text-white mb-1">{formatCurrency(animAgencyMonthly)}<span className="text-lg font-medium" style={{ color: '#7a93ff' }}>/month</span></p>
                <p className="text-lg font-semibold mt-2" style={{ color: 'rgba(122,147,255,0.8)' }}>{formatCurrency(animAgencyAnnual)}/year</p>
              </div>

              {/* Side-by-side: Agency vs Creator */}
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                {/* Agency Take */}
                <div className="rounded-2xl p-5" style={{ backgroundColor: 'rgba(220,38,38,0.04)', border: '1px solid rgba(220,38,38,0.12)' }}>
                  <div className="flex items-center gap-2 mb-4">
                    <div className="w-10 h-10 rounded-xl flex items-center justify-center" style={{ backgroundColor: 'rgba(220,38,38,0.1)' }}>
                      <TrendingDown className="w-5 h-5" style={{ color: '#dc2626' }} />
                    </div>
                    <h3 className="font-bold text-sm" style={{ color: '#dc2626' }}>Agency Take</h3>
                  </div>
                  <div className="space-y-3">
                    <div className="flex justify-between items-center">
                      <span className="text-sm text-muted-foreground">Monthly</span>
                      <span className="text-lg font-bold" style={{ color: '#dc2626' }}>{formatCurrency(animAgencyMonthly)}</span>
                    </div>
                    <div className="h-px" style={{ backgroundColor: 'rgba(220,38,38,0.1)' }} />
                    <div className="flex justify-between items-center">
                      <span className="text-sm text-muted-foreground">Annual</span>
                      <span className="text-lg font-bold" style={{ color: '#dc2626' }}>{formatCurrency(animAgencyAnnual)}</span>
                    </div>
                    <div className="h-px" style={{ backgroundColor: 'rgba(220,38,38,0.1)' }} />
                    <div className="flex justify-between items-center">
                      <span className="text-sm text-muted-foreground">Percentage</span>
                      <span className="text-lg font-bold" style={{ color: '#dc2626' }}>{agencyFee}%</span>
                    </div>
                  </div>
                </div>

                {/* Creator Take */}
                <div className="rounded-2xl p-5" style={{ backgroundColor: 'rgba(41,79,246,0.04)', border: '1px solid rgba(41,79,246,0.12)' }}>
                  <div className="flex items-center gap-2 mb-4">
                    <div className="w-10 h-10 rounded-xl flex items-center justify-center" style={{ backgroundColor: 'rgba(41,79,246,0.12)' }}>
                      <TrendingUp className="w-5 h-5" style={{ color: '#294ff6' }} />
                    </div>
                    <h3 className="font-bold text-sm" style={{ color: '#294ff6' }}>Creator Take</h3>
                  </div>
                  <div className="space-y-3">
                    <div className="flex justify-between items-center">
                      <span className="text-sm text-muted-foreground">Monthly</span>
                      <span className="text-lg font-bold" style={{ color: '#294ff6' }}>{formatCurrency(animCreatorMonthly)}</span>
                    </div>
                    <div className="h-px" style={{ backgroundColor: 'rgba(41,79,246,0.1)' }} />
                    <div className="flex justify-between items-center">
                      <span className="text-sm text-muted-foreground">Annual</span>
                      <span className="text-lg font-bold" style={{ color: '#294ff6' }}>{formatCurrency(animCreatorAnnual)}</span>
                    </div>
                    <div className="h-px" style={{ backgroundColor: 'rgba(41,79,246,0.1)' }} />
                    <div className="flex justify-between items-center">
                      <span className="text-sm text-muted-foreground">Percentage</span>
                      <span className="text-lg font-bold" style={{ color: '#294ff6' }}>{creatorPct}%</span>
                    </div>
                  </div>
                </div>
              </div>

              {/* Stacked Bar Visual */}
              <div className="rounded-xl p-5" style={{ backgroundColor: '#eef4fd' }}>
                <p className="text-xs font-semibold uppercase tracking-wide text-center mb-4" style={{ color: '#000f4d' }}>Commission Split</p>
                <div className="h-6 rounded-full overflow-hidden flex" style={{ backgroundColor: 'rgba(255,255,255,0.8)' }}>
                  <div
                    className="h-full transition-all duration-500 ease-out flex items-center justify-center"
                    style={{
                      width: `${agencyPct}%`,
                      backgroundColor: '#dc2626',
                      minWidth: agencyPct > 0 ? '2rem' : '0',
                    }}
                  >
                    {agencyPct >= 10 && <span className="text-xs font-bold text-white">{agencyPct}%</span>}
                  </div>
                  <div
                    className="h-full transition-all duration-500 ease-out flex items-center justify-center"
                    style={{
                      width: `${creatorPct}%`,
                      background: 'linear-gradient(90deg, #294ff6, #5e7bf6)',
                      minWidth: creatorPct > 0 ? '2rem' : '0',
                    }}
                  >
                    {creatorPct >= 10 && <span className="text-xs font-bold text-white">{creatorPct}%</span>}
                  </div>
                </div>
                <div className="flex justify-between mt-2">
                  <div className="flex items-center gap-2">
                    <div className="w-3 h-3 rounded-sm" style={{ backgroundColor: '#dc2626' }} />
                    <span className="text-xs text-muted-foreground">Agency ({agencyPct}%)</span>
                  </div>
                  <div className="flex items-center gap-2">
                    <div className="w-3 h-3 rounded-sm" style={{ backgroundColor: '#294ff6' }} />
                    <span className="text-xs text-muted-foreground">You keep ({creatorPct}%)</span>
                  </div>
                </div>
              </div>

              {/* Solo Earnings Callout */}
              <div className="rounded-xl p-5 text-center" style={{ backgroundColor: 'rgba(41,79,246,0.06)', border: '1px solid rgba(41,79,246,0.12)' }}>
                <div className="w-10 h-10 rounded-xl mx-auto mb-3 flex items-center justify-center" style={{ backgroundColor: 'rgba(41,79,246,0.12)' }}>
                  <DollarSign className="w-5 h-5" style={{ color: '#294ff6' }} />
                </div>
                <p className="text-sm font-medium text-muted-foreground mb-1">Without an agency, you would keep</p>
                <p className="text-2xl font-bold mb-1" style={{ color: '#294ff6' }}>{formatCurrency(animGrossMonthly)}/month</p>
                <p className="text-sm font-semibold" style={{ color: '#5e7bf6' }}>({formatCurrency(animGrossMonthly * 12)}/year)</p>
              </div>
            </CardContent>
          </Card>

          {/* Calculator Inputs Explained */}
          <Card className="border-0 shadow-lg overflow-hidden" style={{ backgroundColor: '#f8fbff' }}>
            <div className="px-8 py-6" style={{ background: 'linear-gradient(135deg, #152237 0%, #000f4d 100%)' }}>
              <div className="flex items-center gap-3">
                <div className="w-10 h-10 rounded-xl flex items-center justify-center" style={{ backgroundColor: 'rgba(41,79,246,0.2)' }}>
                  <Info className="w-5 h-5" style={{ color: '#7a93ff' }} />
                </div>
                <div>
                  <h2 className="text-xl font-bold text-white">Calculator Inputs Explained</h2>
                  <p className="text-sm" style={{ color: '#7a93ff' }}>Understand each input to get the most accurate results</p>
                </div>
              </div>
            </div>

            <CardContent className="p-8">
              <div className="overflow-x-auto">
                <table className="w-full">
                  <thead>
                    <tr style={{ borderBottom: '2px solid #eef4fd' }}>
                      <th className="text-left py-3 px-4 font-bold text-sm" style={{ color: '#000f4d' }}>Input</th>
                      <th className="text-left py-3 px-4 font-bold text-sm" style={{ color: '#000f4d' }}>Description</th>
                      <th className="text-left py-3 px-4 font-bold text-sm" style={{ color: '#000f4d' }}>Example</th>
                    </tr>
                  </thead>
                  <tbody>
                    {[
                      { name: 'Monthly GMV', desc: 'Total sales value generated through your affiliate links each month', example: formatWhole(25000), required: true },
                      { name: 'Commission Rate', desc: 'The percentage you earn from each sale (set by the seller or platform)', example: '10%', required: true },
                      { name: 'Agency Fee', desc: 'The percentage your agency takes from your commission earnings', example: '20%', required: true },
                    ].map((row, i) => (
                      <tr key={i} className="transition-colors" style={{ borderBottom: '1px solid #eef4fd' }}>
                        <td className="py-4 px-4">
                          <div className="flex items-center gap-2">
                            <span className="font-semibold text-sm" style={{ color: '#000f4d' }}>{row.name}</span>
                            {row.required && (
                              <span className="text-xs px-2 py-0.5 rounded-full font-medium" style={{ backgroundColor: '#d8d8ff', color: '#5e7bf6' }}>Required</span>
                            )}
                          </div>
                        </td>
                        <td className="py-4 px-4 text-sm" style={{ color: 'rgba(0,15,77,0.6)' }}>{row.desc}</td>
                        <td className="py-4 px-4 font-bold text-sm" style={{ color: '#294ff6' }}>{row.example}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              <div className="mt-6 flex items-start gap-3 rounded-xl p-4" style={{ backgroundColor: '#eef4fd' }}>
                <Info className="w-4 h-4 mt-0.5 flex-shrink-0" style={{ color: '#5e7bf6' }} />
                <p className="text-sm" style={{ color: 'rgba(0,15,77,0.7)' }}>
                  Agency fees are typically negotiable. If your agency takes 20%+ of your commission, make sure they are delivering value in the form of higher commission rates, more brand deals, or significant GMV growth.
                </p>
              </div>
            </CardContent>
          </Card>
        </div>
      </div>

      <style jsx>{`
        .cs-slider {
          -webkit-appearance: none;
          appearance: none;
          width: 100%;
          height: 8px;
          border-radius: 4px;
          outline: none;
          cursor: pointer;
          transition: opacity 0.15s;
        }
        .cs-slider::-webkit-slider-thumb {
          -webkit-appearance: none;
          appearance: none;
          width: 24px;
          height: 24px;
          border-radius: 50%;
          background: white;
          border: 3px solid #294ff6;
          box-shadow: 0 2px 8px rgba(41,79,246,0.3);
          cursor: pointer;
          transition: transform 0.15s, box-shadow 0.15s;
        }
        .cs-slider::-webkit-slider-thumb:hover {
          transform: scale(1.15);
          box-shadow: 0 2px 12px rgba(41,79,246,0.45);
        }
        .cs-slider::-moz-range-thumb {
          width: 24px;
          height: 24px;
          border-radius: 50%;
          background: white;
          border: 3px solid #294ff6;
          box-shadow: 0 2px 8px rgba(41,79,246,0.3);
          cursor: pointer;
        }
      `}</style>
    </div>
  );
}
