              <div className="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                {videos.map((vid, i) => (
                  <div key={i} className="space-y-3 group">
                    {vid.embed ? (
                      <div className="aspect-[9/16] w-full rounded-xl overflow-hidden" style={{ backgroundColor: CS.light2 }}>
                        <iframe
                          src={vid.embed}
                          className="w-full h-full"
                          allowFullScreen
                          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        />
                      </div>
                    ) : vid.url ? (
                      <a href={vid.url} target="_blank" rel="noopener noreferrer" className="block aspect-[9/16] w-full rounded-xl flex items-center justify-center transition-colors" style={{ backgroundColor: CS.light2 }}>
                        <Video className="h-10 w-10" style={{ color: CS.blue4 }} />
                      </a>
                    ) : (
                      <div className="aspect-[9/16] w-full rounded-xl flex items-center justify-center" style={{ backgroundColor: CS.light2 }}>
                        <Video className="h-10 w-10" style={{ color: CS.blue4 }} />
                      </div>
                    )}
                    <div className="space-y-1.5">
                      <h4 className="font-medium text-sm line-clamp-2" style={{ color: CS.navy }}>{vid.title}</h4>
                      <div className="flex flex-wrap gap-3 text-xs text-muted-foreground">
                        {vid.views && (
                          <span className="flex items-center gap-1">
                            <Eye className="h-3 w-3" style={{ color: CS.blue3 }} /> {vid.views}
                          </span>
                        )}
                        {vid.likes && (
                          <span className="flex items-center gap-1">
                            <Heart className="h-3 w-3" style={{ color: CS.red }} /> {vid.likes}
                          </span>
                        )}
                      </div>
                      {vid.date && (
                        <div className="text-xs text-muted-foreground flex items-center gap-1">
                          <Calendar className="h-3 w-3" style={{ color: CS.blue4 }} /> {new Date(vid.date).toLocaleDateString()}
                        </div>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </CardContent>
          </Card>
        )}
      </div>
    </div>
  );
}
