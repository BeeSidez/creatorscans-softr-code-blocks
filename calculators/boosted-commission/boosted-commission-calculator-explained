                    <div
                      key={index}
                      className="flex items-start gap-3 rounded-xl p-3 transition-all"
                      style={{
                        backgroundColor: item.avoid ? 'rgba(220,38,38,0.04)' : 'rgba(41,79,246,0.04)',
                        border: item.avoid ? '1px solid rgba(220,38,38,0.1)' : '1px solid rgba(41,79,246,0.06)',
                      }}
                    >
                      <div
                        className="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5"
                        style={{
                          backgroundColor: item.avoid ? 'rgba(220,38,38,0.12)' : 'rgba(41,79,246,0.12)',
