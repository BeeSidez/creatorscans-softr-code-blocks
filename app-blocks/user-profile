// ─── Assets ───────────────────────────────────────────────────────
const TIKTOK_LOGO =
  "https://res.cloudinary.com/dmrekfwpj/image/upload/v1776343756/tiktok_logo_wht_tras_bkg_zk9cqt.png";

const TIKTOK_OAUTH_BASE =
  "https://www.tiktok.com/v2/auth/authorize/?client_key=sbaw80qjizq8tx78nd&scope=user.info.basic%2Cuser.info.profile%2Cuser.info.stats%2Cvideo.list%2Cvideo.publish%2Cvideo.upload&response_type=code&redirect_uri=https%3A%2F%2Fwww.creatorscans.com%2Fdashboard";

// ─── Field map (Users table). Keys are aliases used everywhere ────
const select = q.select({
  email: "T3cFq",
  fullName: "PXdkq",
  avatar: "8L9hV",
  tiktokUsername: "uZ8z0",
  tiktokConnected: "gfgBN",
  shopBound: "bTOzJ",
  liveBound: "sZ3R2",
  bio: "on8OZ",
  tagline: "v2Gu1",
  myGoal: "uNdfV",
  city: "z4TF1",
  pronouns: "W933n",
  gender: "ZrMCm",
  birthday: "A79E9",
  jobTitle: "6aChZ",
  heritage: "FzvXF",
  regionalAccent: "TV7Nz",
  firstLanguage: "3hJpt",
  localDialect: "aWNgr",
});

// ─── Option UUIDs ─────────────────────────────────────────────────
const PRONOUNS_OPTIONS = [
  { id: "7c923ac9-29b6-4f43-9bdd-26c41f3d4a87", label: "She" },
  { id: "4561af4c-a1db-4d5b-8f8c-dbf4f138cc58", label: "Her" },
  { id: "3bad761c-42fa-48f4-ac62-6dbfd01c4871", label: "He" },
  { id: "6ea6a342-d2a1-43cc-ba97-0623e98b4310", label: "Him" },
  { id: "b4a5a067-6f04-461b-8f5e-f08055c27f04", label: "They" },
  { id: "d767bc88-9aca-4983-9e45-5a2bdaaa069c", label: "Them" },
];

const GENDER_OPTIONS = [
  { id: "dbf0be9b-2b73-4e0a-b27d-cdaff23f70ce", label: "Female" },
  { id: "5734272f-f846-47fb-a3b8-e594e24570aa", label: "Male" },
];

const REGIONAL_ACCENT_OPTIONS = [
  { id: "f36ac53b-e31a-4ee1-a40a-fd17a0001754", label: "London / South East" },
  { id: "d35b42ac-f606-431d-a97b-6b61fb3203c7", label: "Midlands" },
  { id: "f7c13297-d00e-4f12-9c1a-1cc2262e91e9", label: "North West" },
  { id: "a35d5e8a-c00e-4494-ac5e-e12129e8842c", label: "North East" },
  { id: "00372359-9b6a-4d07-97ad-a973a07aad2a", label: "Yorkshire" },
  { id: "8c6a285c-eceb-45eb-8fa0-b2b8f55eeaf6", label: "Scottish" },
  { id: "a24a3812-a9ad-4476-9366-be0d489463f9", label: "Welsh" },
  { id: "3f0ddb59-b9c9-4a01-89a8-722125ef34b4", label: "Northern Irish" },
  { id: "7cd041dd-dd06-4128-a650-376ea9edd022", label: "Other" },
];

const SELECT_OPTIONS_BY_ALIAS = {
  pronouns: PRONOUNS_OPTIONS,
  gender: GENDER_OPTIONS,
  regionalAccent: REGIONAL_ACCENT_OPTIONS,
};

// ─── Helpers ──────────────────────────────────────────────────────
function getLabel(options, value) {
  if (!value) return "";
  const id = typeof value === "object" ? value.id : value;
  const found = options.find((o) => o.id === id);
  return found ? found.label : "";
}

function generateOAuthState() {
  return Math.random().toString(36).slice(2) + Date.now().toString(36);
}

// ─── Sub-components ───────────────────────────────────────────────
function DisplayField({ label, value }) {
  return (
    <div className="space-y-1">
      <Label className="text-xs" style={{ color: CS_MUTED }}>{label}</Label>
      <div className="text-sm" style={{ color: CS_NAVY }}>
        {value === true ? "Yes" : value === false ? "No" : value || "—"}
      </div>
    </div>
  );
}

function TextField({ label, value, onChange, multiline }) {
  return (
    <div className="space-y-2">
      <Label className="text-sm" style={{ color: CS_NAVY }}>{label}</Label>
      {multiline ? (
        <Textarea value={value} onChange={(e) => onChange(e.target.value)} rows={3} />
      ) : (
        <Input value={value} onChange={(e) => onChange(e.target.value)} />
      )}
    </div>
  );
}

function SelectField({ label, value, onChange, options }) {
  return (
    <div className="space-y-2">
      <Label className="text-sm" style={{ color: CS_NAVY }}>{label}</Label>
      <Select value={value} onValueChange={onChange}>
        <SelectTrigger>
          <SelectValue placeholder={`Select ${label.toLowerCase()}`} />
        </SelectTrigger>
        <SelectContent>
          {options.map((opt) => (
            <SelectItem key={opt.id} value={opt.id}>
              {opt.label}
            </SelectItem>
          ))}
        </SelectContent>
      </Select>
    </div>
  );
}

function SectionCard({ title, isEditing, onEdit, onSave, onCancel, isSaving, children }) {
  return (
    <Card className="bg-white" style={{ borderColor: CS_BORDER }}>
      <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-4">
        <CardTitle className="text-lg font-semibold" style={{ color: CS_NAVY }}>
          {title}
        </CardTitle>
        <div className="flex gap-2">
          {!isEditing ? (
            <Button variant="ghost" size="sm" onClick={onEdit} style={{ color: CS_PERIWINKLE }}>
              <Edit2 className="h-4 w-4" />
            </Button>
          ) : (
            <>
              <Button variant="ghost" size="sm" onClick={onCancel} disabled={isSaving}>
                <X className="h-4 w-4" />
              </Button>
              <Button
                size="sm"
                onClick={onSave}
                disabled={isSaving}
                style={{ backgroundColor: CS_PERIWINKLE, color: "#fff" }}
              >
                {isSaving ? "Saving…" : <><Save className="h-4 w-4 mr-1" /> Save</>}
              </Button>
            </>
          )}
        </div>
      </CardHeader>
      <CardContent>{children}</CardContent>
    </Card>
  );
}

function BoundChip({ label, bound }) {
  return (
    <div
      className="inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-xs font-medium"
      style={{
        backgroundColor: bound ? "rgba(122,147,255,0.10)" : "rgba(0,0,0,0.04)",
        color: bound ? CS_NAVY : CS_MUTED,
        border: bound ? `1px solid ${CS_PERIWINKLE}40` : "1px solid transparent",
      }}
    >
      {bound ? (
        <Check className="h-3 w-3" style={{ color: CS_PERIWINKLE }} strokeWidth={3} />
      ) : (
        <X className="h-3 w-3" strokeWidth={3} />
      )}
      {label} agency
    </div>
  );
}

// ─── Main Block ───────────────────────────────────────────────────
export default function Block() {
  const recordId = useCurrentRecordId();
  const { data, status, refetch } = useRecord({ recordId, select });

  const [editSection, setEditSection] = useState(null);
  const [saving, setSaving] = useState(false);
  const [draft, setDraft] = useState({});

  const updateRecord = useRecordUpdate({
    fields: select,
    async onSuccess() {
      await refetch();
      toast.success("Profile updated");
      setEditSection(null);
      setSaving(false);
    },
    onError(err) {
      console.error("=== user-profile save error:", err);
      toast.error("Save failed", {
        description: err?.message || "Open the browser console for details.",
      });
      setSaving(false);
    },
  });

  if (status === "pending") {
    return (
      <div className="container py-12">
        <div className="content flex items-center justify-center min-h-[400px]">
          <div style={{ color: CS_MUTED }}>Loading profile…</div>
        </div>
      </div>
    );
  }

  if (status === "error" || !data) {
    return (
      <div className="container py-12">
        <div className="content flex items-center justify-center min-h-[400px]">
          <div className="text-destructive">Couldn't load your profile.</div>
        </div>
      </div>
    );
  }

  const avatarUrl =
    Array.isArray(data.fields.avatar) && data.fields.avatar.length > 0
      ? data.fields.avatar[0].url
      : null;
  const initials = data.fields.fullName
    ? data.fields.fullName
        .split(" ")
        .map((n) => n[0])
        .join("")
        .toUpperCase()
        .slice(0, 2)
    : "?";

  // Connection status comes from the dedicated tiktokConnected boolean
  // (gfgBN). Bev's n8n OAuth callback flips this true on success.
  const isConnected = !!data.fields.tiktokConnected;

  const startEdit = (section, initialData) => {
    setEditSection(section);
    setDraft(initialData);
  };

  const cancelEdit = () => {
    setEditSection(null);
    setDraft({});
  };

  // KEYS in the saved fields object MUST be aliases (matching q.select),
  // not field IDs. Sending field IDs as keys causes Softr to silently
  // strip them all and return "Record data cannot be empty" (see docs).
  const saveSection = (aliases) => {
    setSaving(true);
    const updates = {};
    aliases.forEach((alias) => {
      let value = draft[alias];
      // Single-select fields write as { id, label }, not as plain UUID.
      if (typeof value === "string" && value && SELECT_OPTIONS_BY_ALIAS[alias]) {
        const opt = SELECT_OPTIONS_BY_ALIAS[alias].find((o) => o.id === value);
        value = opt ? { id: opt.id, label: opt.label } : null;
      }
      updates[alias] = value;
    });
    console.log("=== user-profile save:", JSON.stringify(updates, null, 2));
    updateRecord.mutate({ recordId: data.id, fields: updates });
  };

  const handleConnect = () => {
    const state = generateOAuthState();
    try {
      sessionStorage.setItem("cs_tiktok_oauth_state", state);
    } catch (e) {
      // sessionStorage might be blocked; proceed anyway
    }
    window.location.href = `${TIKTOK_OAUTH_BASE}&state=${state}`;
  };

  const handleDisconnect = () => {
    if (
      !window.confirm(
        "Disconnect TikTok? Your stats and agency invite will stop syncing until you reconnect.",
      )
    )
      return;
    setSaving(true);
    updateRecord.mutate({
      recordId: data.id,
      fields: {
        tiktokConnected: false,
        shopBound: false,
        liveBound: false,
      },
    });
  };

  return (
    <>
      <Toaster />
      <div className="container py-8">
        <div className="content max-w-4xl mx-auto space-y-6">
          {/* ─── Profile (avatar + name + email + bio + tagline) ─── */}
          <SectionCard
            title="Profile"
            isEditing={editSection === "profile"}
            onEdit={() =>
              startEdit("profile", {
                fullName: data.fields.fullName || "",
                bio: data.fields.bio || "",
                tagline: data.fields.tagline || "",
              })
            }
            onSave={() => saveSection(["fullName", "bio", "tagline"])}
            onCancel={cancelEdit}
            isSaving={saving}
          >
            {editSection === "profile" ? (
              <div className="space-y-4">
                <div className="flex items-center gap-4">
                  <Avatar className="h-20 w-20">
                    <AvatarImage src={avatarUrl || undefined} />
                    <AvatarFallback style={{ backgroundColor: CS_BORDER, color: CS_NAVY }}>
                      {initials}
                    </AvatarFallback>
                  </Avatar>
                  <div className="text-xs" style={{ color: CS_MUTED }}>
                    Profile picture comes from your connected TikTok account.
                  </div>
                </div>
                <TextField
                  label="Full Name"
                  value={draft.fullName}
                  onChange={(v) => setDraft({ ...draft, fullName: v })}
                />
                <TextField
                  label="Bio"
                  value={draft.bio}
                  onChange={(v) => setDraft({ ...draft, bio: v })}
                  multiline
                />
                <TextField
                  label="Tagline"
                  value={draft.tagline}
                  onChange={(v) => setDraft({ ...draft, tagline: v })}
                />
              </div>
            ) : (
              <div className="space-y-4">
                <div className="flex items-center gap-4">
                  <Avatar className="h-20 w-20">
                    <AvatarImage src={avatarUrl || undefined} />
                    <AvatarFallback style={{ backgroundColor: CS_BORDER, color: CS_NAVY }}>
                      {initials}
                    </AvatarFallback>
                  </Avatar>
                  <div>
                    <h2 className="text-2xl font-bold" style={{ color: CS_NAVY }}>
                      {data.fields.fullName || "No name"}
                    </h2>
                    <p className="text-sm" style={{ color: CS_MUTED }}>
                      {data.fields.email}
                    </p>
                  </div>
                </div>
                <DisplayField label="Bio" value={data.fields.bio} />
                <DisplayField label="Tagline" value={data.fields.tagline} />
              </div>
            )}
          </SectionCard>

          {/* ─── Personal Details (no Age — derived from birthday) ─── */}
          <SectionCard
            title="Personal Details"
            isEditing={editSection === "personal"}
            onEdit={() =>
              startEdit("personal", {
                pronouns: data.fields.pronouns?.id || "",
                gender: data.fields.gender?.id || "",
                birthday: data.fields.birthday || "",
              })
            }
            onSave={() => saveSection(["pronouns", "gender", "birthday"])}
            onCancel={cancelEdit}
            isSaving={saving}
          >
            {editSection === "personal" ? (
              <div className="grid md:grid-cols-2 gap-4">
                <SelectField
                  label="Pronouns"
                  value={draft.pronouns}
                  onChange={(v) => setDraft({ ...draft, pronouns: v })}
                  options={PRONOUNS_OPTIONS}
                />
                <SelectField
                  label="Gender"
                  value={draft.gender}
                  onChange={(v) => setDraft({ ...draft, gender: v })}
                  options={GENDER_OPTIONS}
                />
                <div className="md:col-span-2 space-y-2">
                  <Label className="text-sm" style={{ color: CS_NAVY }}>Birthday</Label>
                  <Input
                    type="date"
                    value={draft.birthday}
                    onChange={(e) => setDraft({ ...draft, birthday: e.target.value })}
                  />
                </div>
              </div>
            ) : (
              <div className="grid md:grid-cols-2 gap-4">
                <DisplayField label="Pronouns" value={getLabel(PRONOUNS_OPTIONS, data.fields.pronouns)} />
                <DisplayField label="Gender" value={getLabel(GENDER_OPTIONS, data.fields.gender)} />
                <DisplayField label="Birthday" value={data.fields.birthday} />
              </div>
            )}
          </SectionCard>

          {/* ─── Location & Language ─── */}
          <SectionCard
            title="Location & Language"
            isEditing={editSection === "location"}
            onEdit={() =>
              startEdit("location", {
                city: data.fields.city || "",
                heritage: data.fields.heritage || "",
                regionalAccent: data.fields.regionalAccent?.id || "",
                firstLanguage: data.fields.firstLanguage || "",
                localDialect: data.fields.localDialect || false,
              })
            }
            onSave={() =>
              saveSection(["city", "heritage", "regionalAccent", "firstLanguage", "localDialect"])
            }
            onCancel={cancelEdit}
            isSaving={saving}
          >
            {editSection === "location" ? (
              <div className="grid md:grid-cols-2 gap-4">
                <TextField
                  label="City"
                  value={draft.city}
                  onChange={(v) => setDraft({ ...draft, city: v })}
                />
                <TextField
                  label="Heritage"
                  value={draft.heritage}
                  onChange={(v) => setDraft({ ...draft, heritage: v })}
                />
                <SelectField
                  label="Regional Accent"
                  value={draft.regionalAccent}
                  onChange={(v) => setDraft({ ...draft, regionalAccent: v })}
                  options={REGIONAL_ACCENT_OPTIONS}
                />
                <TextField
                  label="First Language"
                  value={draft.firstLanguage}
                  onChange={(v) => setDraft({ ...draft, firstLanguage: v })}
                />
                <div className="md:col-span-2 flex items-start gap-3 rounded-xl p-3" style={{ backgroundColor: CS_BORDER }}>
                  <Checkbox
                    id="localDialect"
                    checked={draft.localDialect}
                    onCheckedChange={(checked) => setDraft({ ...draft, localDialect: !!checked })}
                    className="mt-0.5"
                  />
                  <Label htmlFor="localDialect" className="text-sm cursor-pointer" style={{ color: CS_NAVY }}>
                    I post in my local dialect (used to write scripts in your voice)
                  </Label>
                </div>
              </div>
            ) : (
              <div className="grid md:grid-cols-2 gap-4">
                <DisplayField label="City" value={data.fields.city} />
                <DisplayField label="Heritage" value={data.fields.heritage} />
                <DisplayField
                  label="Regional Accent"
                  value={getLabel(REGIONAL_ACCENT_OPTIONS, data.fields.regionalAccent)}
                />
                <DisplayField label="First Language" value={data.fields.firstLanguage} />
                <DisplayField label="Local Dialect" value={data.fields.localDialect} />
              </div>
            )}
          </SectionCard>

          {/* ─── Career ─── */}
          <SectionCard
            title="Career"
            isEditing={editSection === "career"}
            onEdit={() =>
              startEdit("career", {
                jobTitle: data.fields.jobTitle || "",
              })
            }
            onSave={() => saveSection(["jobTitle"])}
            onCancel={cancelEdit}
            isSaving={saving}
          >
            {editSection === "career" ? (
              <div className="grid md:grid-cols-2 gap-4">
                <TextField
                  label="Job Title"
                  value={draft.jobTitle}
                  onChange={(v) => setDraft({ ...draft, jobTitle: v })}
                />
              </div>
            ) : (
              <div className="grid md:grid-cols-2 gap-4">
                <DisplayField label="Job Title" value={data.fields.jobTitle} />
              </div>
            )}
          </SectionCard>

          {/* ─── Creator Goals ─── */}
          <SectionCard
            title="Creator Goals"
            isEditing={editSection === "goals"}
            onEdit={() =>
              startEdit("goals", {
                myGoal: data.fields.myGoal || "",
              })
            }
            onSave={() => saveSection(["myGoal"])}
            onCancel={cancelEdit}
            isSaving={saving}
          >
            {editSection === "goals" ? (
              <div className="space-y-4">
                <TextField
                  label="My Goal"
                  value={draft.myGoal}
                  onChange={(v) => setDraft({ ...draft, myGoal: v })}
                  multiline
                />
              </div>
            ) : (
              <div className="space-y-4">
                <DisplayField label="My Goal" value={data.fields.myGoal} />
              </div>
            )}
          </SectionCard>

          {/* ─── TikTok Connection (Connect / Disconnect) ─── */}
          <Card className="bg-white" style={{ borderColor: CS_BORDER }}>
            <CardHeader className="pb-4">
              <CardTitle className="text-lg font-semibold" style={{ color: CS_NAVY }}>
                TikTok Connection
              </CardTitle>
            </CardHeader>
            <CardContent>
              <div className="flex items-center justify-between gap-4 flex-wrap">
                <div className="flex items-center gap-3">
                  <div
                    className="rounded-xl flex items-center justify-center shrink-0"
                    style={{ width: 48, height: 48, backgroundColor: "#000624" }}
                  >
                    <img
                      src={TIKTOK_LOGO}
                      alt="TikTok"
                      style={{ width: 28, height: 28, display: "block" }}
                    />
                  </div>
                  <div>
                    {data.fields.tiktokUsername ? (
                      <>
                        <div className="font-semibold" style={{ color: CS_NAVY }}>
                          @{data.fields.tiktokUsername}
                        </div>
                        <div
                          className="flex items-center gap-1.5 text-xs mt-0.5"
                          style={{ color: isConnected ? CS_GREEN : CS_MUTED }}
                        >
                          <span
                            className="rounded-full"
                            style={{
                              width: 6,
                              height: 6,
                              backgroundColor: isConnected ? CS_GREEN : "#9ca3af",
                            }}
                          />
                          {isConnected ? "Connected" : "Not connected"}
                        </div>
                      </>
                    ) : (
                      <>
                        <div className="font-semibold" style={{ color: CS_NAVY }}>
                          No TikTok connected
                        </div>
                        <div className="text-xs mt-0.5" style={{ color: CS_MUTED }}>
                          Connect to import your bio, profile picture, and stats.
                        </div>
                      </>
                    )}
                  </div>
                </div>
                <div>
                  {isConnected ? (
                    <Button
                      variant="outline"
                      onClick={handleDisconnect}
                      disabled={saving}
                      style={{
                        color: CS_MUTED,
                        borderColor: CS_BORDER,
                      }}
                    >
                      Disconnect
                    </Button>
                  ) : (
                    <Button
                      onClick={handleConnect}
                      disabled={saving}
                      className="font-semibold"
                      style={{ backgroundColor: CS_PERIWINKLE, color: "#fff" }}
                    >
                      Connect TikTok
                    </Button>
                  )}
                </div>
              </div>

              {data.fields.tiktokUsername && (
                <div
                  className="mt-5 pt-4 border-t flex flex-wrap gap-3"
                  style={{ borderColor: CS_BORDER }}
                >
                  <BoundChip label="Shop" bound={!!data.fields.shopBound} />
                  <BoundChip label="LIVE" bound={!!data.fields.liveBound} />
                </div>
              )}

              {!isConnected && data.fields.tiktokUsername && (
                <p className="mt-4 text-xs" style={{ color: CS_MUTED }}>
                  Your handle is on file but the agency invite hasn't been sent yet. Connect TikTok to finish.
                </p>
              )}
            </CardContent>
          </Card>
        </div>
      </div>
    </>
  );
}
