  tiktokUsername: "uZ8z0",
  shopBound: "bTOzJ",
  liveBound: "sZ3R2",
  bio: "on8OZ",
  tagline: "v2Gu1",
  myGoal: "uNdfV",
  city: "z4TF1",
  age: "aNbbk",
  pronouns: "W933n",
  gender: "ZrMCm",
  address: "ONDAV",
  birthday: "A79E9",
  jobTitle: "6aChZ",
  industry: "aDyIX",
  position: "1kULp",
  careerStage: "SCLTv",
  income: "iwraT",
  lookingFor: "VzOte",
  heritage: "FzvXF",
  regionalAccent: "TV7Nz",
  firstLanguage: "3hJpt",
  localDialect: "aWNgr",
