function getLabel(options: { id: string; label: string }[], value: { id: string; label: string } | null) {
  if (!value) return "";
  const option = options.find((o) => o.id === value.id);
  return option ? option.label : value.label;
}

function DisplayField({ label, value }: { label: string; value: string | boolean | null | undefined }) {
  return (
    <div className="space-y-1">
      <Label className="text-xs text-muted-foreground">{label}</Label>
      <div className="text-sm">{value === true ? "Yes" : value === false ? "No" : value || "\u2014"}</div>
    </div>
  );
}

function SectionCard({
  title,
  isEditing,
  onEdit,
  onSave,
  onCancel,
  isSaving,
  children,
}: {
  title: string;
  isEditing: boolean;
  onEdit: () => void;
  onSave: () => void;
  onCancel: () => void;
  isSaving: boolean;
  children: React.ReactNode;
}) {
  return (
    <Card className="bg-white" style={{ borderColor: CS_BORDER }}>
      <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-4">
        <CardTitle className="text-lg font-semibold" style={{ color: CS_BLUE }}>
          {title}
        </CardTitle>
        <div className="flex gap-2">
          {!isEditing ? (
            <Button variant="ghost" size="sm" onClick={onEdit} style={{ color: CS_BLUE }}>
              <Edit2 className="h-4 w-4" />
            </Button>
          ) : (
            <>
              <Button variant="ghost" size="sm" onClick={onCancel} disabled={isSaving}>
                <X className="h-4 w-4" />
              </Button>
              <Button
                variant="default"
                size="sm"
                onClick={onSave}
                disabled={isSaving}
                style={{ backgroundColor: CS_BLUE }}
              >
                {isSaving ? "Saving..." : <Save className="h-4 w-4" />}
              </Button>
            </>
          )}
        </div>
      </CardHeader>
      <CardContent>{children}</CardContent>
    </Card>
  );
}

function SelectField({
  label,
  value,
  onChange,
  options,
}: {
  label: string;
  value: string;
  onChange: (value: string) => void;
  options: { id: string; label: string }[];
}) {
  return (
    <div className="space-y-2">
      <Label className="text-sm">{label}</Label>
      <Select value={value} onValueChange={onChange}>
        <SelectTrigger>
          <SelectValue placeholder={`Select ${label.toLowerCase()}`} />
        </SelectTrigger>
        <SelectContent>
          {options.map((opt) => (
            <SelectItem key={opt.id} value={opt.id}>
              {opt.label}
            </SelectItem>
          ))}
        </SelectContent>
      </Select>
    </div>
  );
}

function TextField({
  label,
  value,
  onChange,
  multiline,
}: {
  label: string;
  value: string;
  onChange: (value: string) => void;
  multiline?: boolean;
}) {
  return (
    <div className="space-y-2">
      <Label className="text-sm">{label}</Label>
      {multiline ? (
        <Textarea value={value} onChange={(e) => onChange(e.target.value)} rows={3} />
      ) : (
        <Input value={value} onChange={(e) => onChange(e.target.value)} />
      )}
    </div>
  );
}

export default function Block() {
  const recordId = useCurrentRecordId();
  const { data, status, error, refetch } = useRecord({ recordId, select });

  const [editSection, setEditSection] = useState<string | null>(null);
  const [saving, setSaving] = useState(false);
  const [draft, setDraft] = useState<any>({});

  const updateRecord = useRecordUpdate({
    fields: select,
    async onSuccess() {
      await refetch();
      toast.success("Profile updated successfully!");
      setEditSection(null);
      setSaving(false);
    },
    onError(error) {
      toast.error("Failed to update profile", { description: error.message });
      setSaving(false);
    },
  });

  if (status === "pending") {
    return (
      <div className="container py-12">
        <div className="content flex items-center justify-center min-h-[400px]">
          <div className="text-muted-foreground">Loading profile...</div>
        </div>
      </div>
    );
  }

  if (status === "error" || !data) {
    return (
      <div className="container py-12">
        <div className="content flex items-center justify-center min-h-[400px]">
          <div className="text-destructive">Error loading profile</div>
        </div>
      </div>
    );
  }

  const avatarUrl = Array.isArray(data.fields.avatar) && data.fields.avatar.length > 0 ? data.fields.avatar[0].url : null;
  const initials = data.fields.fullName
    ? data.fields.fullName
        .split(" ")
        .map((n: string) => n[0])
        .join("")
        .toUpperCase()
        .slice(0, 2)
    : "?";

  const startEdit = (section: string, initialData: any) => {
    setEditSection(section);
    setDraft(initialData);
  };

  const cancelEdit = () => {
    setEditSection(null);
    setDraft({});
  };

  const saveSection = async (section: string, fieldMapping: Record<string, string>) => {
    setSaving(true);
    const updates: Record<string, any> = {};
    Object.keys(fieldMapping).forEach((key) => {
      updates[fieldMapping[key]] = draft[key];
    });
    updateRecord.mutate({ recordId: data.id, fields: updates });
  };

  return (
    <>
      <Toaster />
      <div className="container py-8">
        <div className="content max-w-4xl mx-auto space-y-6">
          {/* Profile Section */}
          <SectionCard
            title="Profile"
            isEditing={editSection === "profile"}
            onEdit={() =>
              startEdit("profile", {
                fullName: data.fields.fullName || "",
                bio: data.fields.bio || "",
                tagline: data.fields.tagline || "",
              })
            }
            onSave={() =>
              saveSection("profile", {
                fullName: "PXdkq",
                bio: "on8OZ",
                tagline: "v2Gu1",
              })
            }
            onCancel={cancelEdit}
            isSaving={saving}
          >
            {editSection === "profile" ? (
              <div className="space-y-4">
