import { useState, useEffect, useRef } from 'react';
import { Card, CardContent } from '@/components/ui/card';
import { PoundSterling, TrendingUp, Calendar, Calculator, Info, ChevronDown } from 'lucide-react';

const currencies = [
  { code: 'GBP', symbol: '£', rate: 1 },
  { code: 'USD', symbol: '$', rate: 1.27 },
  { code: 'EUR', symbol: '€', rate: 1.17 },
];

export default function Block() {
  const [productPrice, setProductPrice] = useState(50);
  const [commissionRate, setCommissionRate] = useState(5);
  const [monthlySales, setMonthlySales] = useState(20);
  const [currency, setCurrency] = useState(currencies[0]);
  const [showCurrencyDropdown, setShowCurrencyDropdown] = useState(false);
  const [animatedEPS, setAnimatedEPS] = useState(0);
  const [animatedMonthly, setAnimatedMonthly] = useState(0);
  const [animatedAnnual, setAnimatedAnnual] = useState(0);
  const animFrameRef = useRef(null);
  const dropdownRef = useRef(null);

  const earningsPerSale = (productPrice * commissionRate) / 100;
  const monthlyEarnings = earningsPerSale * monthlySales;
  const annualEarnings = monthlyEarnings * 12;

  // Close dropdown when clicking outside
  useEffect(() => {
    const handleClickOutside = (e) => {
      if (dropdownRef.current && !dropdownRef.current.contains(e.target)) {
        setShowCurrencyDropdown(false);
      }
    };
    document.addEventListener('mousedown', handleClickOutside);
    return () => document.removeEventListener('mousedown', handleClickOutside);
  }, []);

  useEffect(() => {
    const startEPS = animatedEPS;
    const startMonthly = animatedMonthly;
    const startAnnual = animatedAnnual;
    const duration = 400;
    const startTime = Date.now();

    const animate = () => {
      const elapsed = Date.now() - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const ease = 1 - Math.pow(1 - progress, 3);

      setAnimatedEPS(startEPS + (earningsPerSale - startEPS) * ease);
      setAnimatedMonthly(startMonthly + (monthlyEarnings - startMonthly) * ease);
      setAnimatedAnnual(startAnnual + (annualEarnings - startAnnual) * ease);

      if (progress < 1) {
        animFrameRef.current = requestAnimationFrame(animate);
      }
    };

    if (animFrameRef.current) cancelAnimationFrame(animFrameRef.current);
    animFrameRef.current = requestAnimationFrame(animate);

    return () => {
      if (animFrameRef.current) cancelAnimationFrame(animFrameRef.current);
    };
  }, [earningsPerSale, monthlyEarnings, annualEarnings]);

  const convert = (val) => val * currency.rate;

  const formatCurrency = (val) => {
    const converted = convert(val);
    if (currency.rate >= 50) {
      return currency.symbol + Math.round(converted).toLocaleString('en-GB');
    }
    return currency.symbol + converted.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  };

  const formatWhole = (val) => {
    const converted = val * currency.rate;
    if (currency.rate >= 50) {
      return currency.symbol + Math.round(converted).toLocaleString('en-GB');
    }
    return currency.symbol + Math.round(converted).toLocaleString('en-GB');
  };

  const sliderTrackStyle = (value, min, max) => {
    const pct = ((value - min) / (max - min)) * 100;
    return {
      background: `linear-gradient(to right, #294ff6 0%, #5e7bf6 ${pct}%, #eef4fd ${pct}%, #eef4fd 100%)`,
    };
  };

  return (
    <div style={{ background: 'linear-gradient(180deg, #fafbff 0%, #f8fbff 50%, #fafbff 100%)' }}>
      <div className="container py-16">
        <div className="content max-w-5xl mx-auto space-y-8">

          {/* Calculator Card */}
          <Card className="border-0 shadow-lg overflow-hidden" style={{ backgroundColor: '#f8fbff' }}>
            {/* Card Header */}
            <div className="px-8 py-6" style={{ background: 'linear-gradient(135deg, #152237 0%, #000f4d 100%)' }}>
              <div className="flex items-center justify-between flex-wrap gap-4">
                <div className="flex items-center gap-3">
                  <div className="w-10 h-10 rounded-xl flex items-center justify-center" style={{ backgroundColor: 'rgba(41,79,246,0.2)' }}>
                    <Calculator className="w-5 h-5" style={{ color: '#7a93ff' }} />
                  </div>
                  <div>
                    <h2 className="text-xl font-bold text-white">Calculate Commission Earnings</h2>
                    <p className="text-sm" style={{ color: '#7a93ff' }}>Adjust the sliders to see your projected earnings</p>
                  </div>
                </div>

                {/* Currency Selector */}
                <div className="relative" ref={dropdownRef}>
                  <button
                    onClick={() => setShowCurrencyDropdown(!showCurrencyDropdown)}
                    className="flex items-center gap-2 px-3.5 py-2 rounded-lg text-sm font-medium transition-all"
                    style={{
                      backgroundColor: 'rgba(41,79,246,0.2)',
                      border: '1px solid rgba(122,147,255,0.3)',
                      color: '#7a93ff',
                    }}
                  >
                    <span className="font-bold text-white">{currency.symbol}</span>
                    <span>{currency.code}</span>
                    <ChevronDown className="w-3.5 h-3.5" style={{ color: '#7a93ff', transform: showCurrencyDropdown ? 'rotate(180deg)' : 'rotate(0)', transition: 'transform 0.2s' }} />
                  </button>

                  {showCurrencyDropdown && (
                    <div
                      className="absolute right-0 top-full mt-2 rounded-xl shadow-lg overflow-hidden z-50"
                      style={{ backgroundColor: '#152237', border: '1px solid rgba(122,147,255,0.2)', minWidth: '140px' }}
                    >
                      {currencies.map((c) => (
                        <button
                          key={c.code}
                          onClick={() => { setCurrency(c); setShowCurrencyDropdown(false); }}
                          className="w-full px-4 py-2.5 text-left text-sm flex items-center gap-2 transition-colors"
                          style={{
                            color: currency.code === c.code ? 'white' : '#7a93ff',
                            backgroundColor: currency.code === c.code ? 'rgba(41,79,246,0.3)' : 'transparent',
                          }}
                          onMouseEnter={(e) => { if (currency.code !== c.code) e.currentTarget.style.backgroundColor = 'rgba(41,79,246,0.15)'; }}
                          onMouseLeave={(e) => { if (currency.code !== c.code) e.currentTarget.style.backgroundColor = 'transparent'; }}
                        >
                          <span className="font-bold" style={{ color: 'white', width: '24px' }}>{c.symbol}</span>
                          <span>{c.code}</span>
                        </button>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </div>

            <CardContent className="p-8 space-y-8">
              {/* Input: Product Price */}
              <div className="space-y-3">
                <div className="flex items-center justify-between">
                  <label className="text-sm font-semibold" style={{ color: '#000f4d' }}>Product Price</label>
                  <div className="flex items-center gap-1 px-3 py-1.5 rounded-lg" style={{ backgroundColor: '#eef4fd' }}>
                    <span className="text-sm font-bold" style={{ color: '#294ff6' }}>{formatWhole(productPrice)}</span>
                  </div>
                </div>
                <input
                  type="range"
                  min="5"
                  max="500"
                  step="5"
                  value={productPrice}
                  onChange={(e) => setProductPrice(Number(e.target.value))}
                  className="cs-slider"
                  style={sliderTrackStyle(productPrice, 5, 500)}
                />
                <div className="flex justify-between text-xs text-muted-foreground">
                  <span>{formatWhole(5)}</span>
                  <span>{formatWhole(500)}</span>
                </div>
              </div>

              {/* Input: Commission Rate */}
              <div className="space-y-3">
                <div className="flex items-center justify-between">
                  <label className="text-sm font-semibold" style={{ color: '#000f4d' }}>Commission Rate</label>
                  <div className="flex items-center gap-1 px-3 py-1.5 rounded-lg" style={{ backgroundColor: '#eef4fd' }}>
                    <span className="text-sm font-bold" style={{ color: '#294ff6' }}>{commissionRate}%</span>
                  </div>
                </div>
                <input
                  type="range"
                  min="2"
                  max="20"
                  step="1"
                  value={commissionRate}
                  onChange={(e) => setCommissionRate(Number(e.target.value))}
                  className="cs-slider"
                  style={sliderTrackStyle(commissionRate, 2, 20)}
                />
                <div className="flex justify-between text-xs text-muted-foreground">
                  <span>2%</span>
                  <span>20%</span>
                </div>
              </div>

              {/* Input: Monthly Sales */}
              <div className="space-y-3">
                <div className="flex items-center justify-between">
                  <label className="text-sm font-semibold" style={{ color: '#000f4d' }}>Expected Monthly Sales</label>
                  <div className="flex items-center gap-1 px-3 py-1.5 rounded-lg" style={{ backgroundColor: '#eef4fd' }}>
                    <span className="text-sm font-bold" style={{ color: '#294ff6' }}>{monthlySales} sales</span>
                  </div>
                </div>
                <input
                  type="range"
                  min="1"
                  max="500"
                  step="1"
                  value={monthlySales}
                  onChange={(e) => setMonthlySales(Number(e.target.value))}
                  className="cs-slider"
                  style={sliderTrackStyle(monthlySales, 1, 500)}
                />
                <div className="flex justify-between text-xs text-muted-foreground">
                  <span>1</span>
                  <span>500</span>
                </div>
              </div>

              {/* Divider */}
              <div className="h-px" style={{ backgroundColor: '#eef4fd' }} />

              {/* Results */}
              <div className="grid md:grid-cols-3 gap-4">
                {/* Earnings Per Sale */}
                <div className="rounded-2xl p-5 text-center" style={{ backgroundColor: 'rgba(41,79,246,0.06)', border: '1px solid rgba(41,79,246,0.1)' }}>
                  <div className="w-10 h-10 rounded-xl mx-auto mb-3 flex items-center justify-center" style={{ backgroundColor: 'rgba(41,79,246,0.12)' }}>
                    <span className="text-lg font-bold" style={{ color: '#294ff6' }}>{currency.symbol}</span>
                  </div>
                  <p className="text-xs font-medium uppercase tracking-wide text-muted-foreground mb-1">Per Sale</p>
                  <p className="text-3xl font-bold" style={{ color: '#294ff6' }}>{formatCurrency(animatedEPS)}</p>
                </div>

                {/* Monthly Earnings */}
                <div className="rounded-2xl p-5 text-center" style={{ background: 'linear-gradient(135deg, #152237 0%, #000f4d 100%)' }}>
                  <div className="w-10 h-10 rounded-xl mx-auto mb-3 flex items-center justify-center" style={{ backgroundColor: 'rgba(41,79,246,0.25)' }}>
                    <TrendingUp className="w-5 h-5" style={{ color: '#7a93ff' }} />
                  </div>
                  <p className="text-xs font-medium uppercase tracking-wide mb-1" style={{ color: '#7a93ff' }}>Monthly</p>
                  <p className="text-3xl font-bold text-white">{formatCurrency(animatedMonthly)}</p>
                </div>

                {/* Annual Projection */}
                <div className="rounded-2xl p-5 text-center" style={{ backgroundColor: 'rgba(41,79,246,0.06)', border: '1px solid rgba(41,79,246,0.1)' }}>
                  <div className="w-10 h-10 rounded-xl mx-auto mb-3 flex items-center justify-center" style={{ backgroundColor: 'rgba(41,79,246,0.12)' }}>
                    <Calendar className="w-5 h-5" style={{ color: '#294ff6' }} />
                  </div>
                  <p className="text-xs font-medium uppercase tracking-wide text-muted-foreground mb-1">Annual</p>
                  <p className="text-3xl font-bold" style={{ color: '#000f4d' }}>{formatCurrency(animatedAnnual)}</p>
                </div>
              </div>

              {/* Earnings bar visual */}
              <div className="rounded-xl p-4" style={{ backgroundColor: '#eef4fd' }}>
                <div className="flex items-center justify-between mb-2">
                  <span className="text-xs font-medium text-muted-foreground">Monthly earnings breakdown</span>
                  <span className="text-xs font-semibold" style={{ color: '#000f4d' }}>{formatCurrency(animatedMonthly)}/mo</span>
                </div>
                <div className="h-3 rounded-full overflow-hidden" style={{ backgroundColor: 'rgba(255,255,255,0.8)' }}>
                  <div
                    className="h-full rounded-full transition-all duration-500 ease-out"
                    style={{
                      width: `${Math.min((monthlyEarnings / 5000) * 100, 100)}%`,
                      background: 'linear-gradient(90deg, #294ff6 0%, #5e7bf6 50%, #7a93ff 100%)',
                    }}
                  />
                </div>
                <div className="flex justify-between mt-1.5">
                  <span className="text-xs text-muted-foreground">{currency.symbol}0</span>
                  <span className="text-xs text-muted-foreground">{formatWhole(5000)}+</span>
                </div>
              </div>
            </CardContent>
          </Card>

          {/* Calculator Inputs Explained */}
          <Card className="border-0 shadow-lg overflow-hidden" style={{ backgroundColor: '#f8fbff' }}>
            <div className="px-8 py-6" style={{ background: 'linear-gradient(135deg, #152237 0%, #000f4d 100%)' }}>
              <div className="flex items-center gap-3">
                <div className="w-10 h-10 rounded-xl flex items-center justify-center" style={{ backgroundColor: 'rgba(41,79,246,0.2)' }}>
                  <Info className="w-5 h-5" style={{ color: '#7a93ff' }} />
                </div>
                <div>
                  <h2 className="text-xl font-bold text-white">Calculator Inputs Explained</h2>
                  <p className="text-sm" style={{ color: '#7a93ff' }}>Understand each input to get the most accurate results</p>
                </div>
              </div>
            </div>

            <CardContent className="p-8">
              <div className="overflow-x-auto">
                <table className="w-full">
                  <thead>
                    <tr style={{ borderBottom: '2px solid #eef4fd' }}>
                      <th className="text-left py-3 px-4 font-bold text-sm" style={{ color: '#000f4d' }}>Input</th>
                      <th className="text-left py-3 px-4 font-bold text-sm" style={{ color: '#000f4d' }}>Description</th>
                      <th className="text-left py-3 px-4 font-bold text-sm" style={{ color: '#000f4d' }}>Example</th>
                    </tr>
                  </thead>
                  <tbody>
                    {[
                      { name: 'Product Price', desc: 'Your product selling price on TikTok Shop', example: formatWhole(35), required: true },
                      { name: 'Units Sold', desc: 'Number of products sold', example: '500', required: true },
                      { name: 'TikTok Commission', desc: 'TikTok Shop commission rate (2-8%)', example: '5%', required: false },
                      { name: 'Product Cost', desc: 'Your cost per unit including shipping', example: formatWhole(15), required: false },
                    ].map((row, i) => (
                      <tr key={i} className="transition-colors" style={{ borderBottom: '1px solid #eef4fd' }}>
                        <td className="py-4 px-4">
                          <div className="flex items-center gap-2">
                            <span className="font-semibold text-sm" style={{ color: '#000f4d' }}>{row.name}</span>
                            {row.required && (
                              <span className="text-xs px-2 py-0.5 rounded-full font-medium" style={{ backgroundColor: '#d8d8ff', color: '#5e7bf6' }}>Required</span>
                            )}
                          </div>
                        </td>
                        <td className="py-4 px-4 text-sm" style={{ color: 'rgba(0,15,77,0.6)' }}>{row.desc}</td>
                        <td className="py-4 px-4 font-bold text-sm" style={{ color: '#294ff6' }}>{row.example}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              <div className="mt-6 flex items-start gap-3 rounded-xl p-4" style={{ backgroundColor: '#eef4fd' }}>
                <Info className="w-4 h-4 mt-0.5 flex-shrink-0" style={{ color: '#5e7bf6' }} />
                <p className="text-sm" style={{ color: 'rgba(0,15,77,0.7)' }}>
                  TikTok Shop commission varies by category: 2% for essentials, 5% standard, 8% for luxury.
                </p>
              </div>
            </CardContent>
          </Card>
        </div>
      </div>

      <style jsx>{`
        .cs-slider {
          -webkit-appearance: none;
          appearance: none;
          width: 100%;
          height: 8px;
          border-radius: 4px;
          outline: none;
          cursor: pointer;
          transition: opacity 0.15s;
        }
        .cs-slider::-webkit-slider-thumb {
          -webkit-appearance: none;
          appearance: none;
          width: 24px;
          height: 24px;
          border-radius: 50%;
          background: white;
          border: 3px solid #294ff6;
          box-shadow: 0 2px 8px rgba(41,79,246,0.3);
          cursor: pointer;
          transition: transform 0.15s, box-shadow 0.15s;
        }
        .cs-slider::-webkit-slider-thumb:hover {
          transform: scale(1.15);
          box-shadow: 0 2px 12px rgba(41,79,246,0.45);
        }
        .cs-slider::-moz-range-thumb {
          width: 24px;
          height: 24px;
          border-radius: 50%;
          background: white;
          border: 3px solid #294ff6;
          box-shadow: 0 2px 8px rgba(41,79,246,0.3);
          cursor: pointer;
        }
      `}</style>
    </div>
  );
}
