    careerStage: "",
    income: "",
    lookingFor: [],
    myGoal: "",
  });

  // Tracks whether the in-flight save was triggered by Connect TikTok
  // (so onSuccess knows it needs to do the OAuth redirect after).
  const oauthPendingRef = useRef(false);

  // Diagnostic: Softr's internal fetch wrapper throws away the
  // response body on errors, so we never see WHY a 400 happened.
  // Monkey-patch window.fetch while this block is mounted to clone
  // and log the response body whenever a records-trigger request
  // fails. Cleans up on unmount so it doesn't affect other pages.
  useEffect(() => {
    const original = window.fetch;
    window.fetch = async function (...args) {
      const response = await original.apply(this, args);
      try {
        const url = typeof args[0] === "string" ? args[0] : args[0]?.url || "";
        if (url.includes("records-trigger") && !response.ok) {
          const body = await response.clone().text();
          console.error(
            "=== Softr records-trigger error",
            response.status,
            response.statusText,
            "\nURL:",
            url,
            "\nResponse body:",
            body,
          );
        }
      } catch (e) {
        console.error("=== fetch interceptor failed:", e);
      }
      return response;
    };
    return () => {
      window.fetch = original;
    };
  }, []);

  const updateRecord = useRecordUpdate({
    fields: select,
    onSuccess() {
      if (!oauthPendingRef.current) return;
      oauthPendingRef.current = false;

      // Server confirmed the save. Now safe to fire CSRF state +
      // navigate away — no race with an in-flight write.
      const state = generateOAuthState();
      try {
        sessionStorage.setItem("cs_tiktok_oauth_state", state);
      } catch (e) {
        // sessionStorage might be blocked; proceed anyway
      }
      window.location.href = `${TIKTOK_OAUTH_BASE}&state=${state}`;
    },
    onError(err) {
      console.error("=== onboarding save error:", err);
      oauthPendingRef.current = false;
      toast.error("Save failed", {
        description: err?.message || "Open the browser console for details.",
      });
      setSaving(false);
    },
  });

  const set = (key, value) => setForm((f) => ({ ...f, [key]: value }));

  const toggleInArray = (key, id) => {
    setForm((f) => {
      const arr = f[key] || [];
      return {
        ...f,
        [key]: arr.includes(id) ? arr.filter((x) => x !== id) : [...arr, id],
      };
    });
  };

  const goNext = () => setStepIdx((i) => Math.min(i + 1, STEPS.length - 1));
  const goBack = () => setStepIdx((i) => Math.max(i - 1, 0));

  // ─── Per-step validators ──────────────────────────────────────
  // Each step just validates and advances. Nothing writes to the
  // database until the final Connect TikTok step does one big atomic
  // save. If the user bails before that, no half-finished record.
  const continueWelcome = () => goNext();

  const continueTrack = () => {
    if (form.track.length === 0) return;
    goNext();
  };

  const continueCadence = () => {
    const selectedKeys = TRACK_OPTIONS.filter((t) => form.track.includes(t.key)).map((t) => t.key);
    const allPicked = selectedKeys.every((k) => !!form.membershipsByTrack[k]);
    if (!allPicked) return;
    goNext();
  };

  const continueAbout = () => {
    if (!form.gender || !form.pronouns || !form.birthday) return;
    if (!isAtLeast18(form.birthday)) {
      toast.error("You must be 18 or over to join Creator Scans.");
      return;
    }
    goNext();
  };

  const continueWhere = () => {
    // Local dialect is a checkbox so unticked is a valid answer (means "no").
    if (
      !form.city.trim() ||
      !form.regionalAccent ||
      !form.heritage.trim() ||
      !form.firstLanguage.trim()
    )
      return;
    goNext();
  };

  const continueCareer = () => {
    if (
      !form.jobTitle.trim() ||
      !form.industry ||
      !form.position ||
      !form.careerStage ||
      !form.income
    )
      return;
    goNext();
  };

  const continueWhy = () => {
    if (form.lookingFor.length === 0 || !form.myGoal.trim()) return;
    goNext();
  };

  // ─── Build the single atomic save payload ─────────────────────
  // Format per field type (matches the working user-profile block):
  //   Single select  -> { id, label }   object
  //   Multi-select   -> [uuid, uuid]    array of UUID strings
  //   Linked record  -> [{ id }]        array of {id} objects
  //   Industry / Position / Career Stage / Income are multi in the
  //   schema but single-pick in the UI, so we wrap each in a one-item
  //   array of UUIDs.
  const toIdLabel = (options, id) => {
    const opt = options.find((o) => o.id === id);
    return opt ? { id: opt.id, label: opt.label } : null;
  };

  const buildUpdates = () => {
    const membershipIds = TRACK_OPTIONS
      .filter((t) => form.track.includes(t.key))
      .map((t) => form.membershipsByTrack[t.key])
      .filter(Boolean)
      .map((id) => ({ id }));

    // Keys are the ALIASES from q.select, NOT field IDs. Softr's data
    // layer maps alias -> field ID internally. Sending field IDs as
    // keys results in every field being stripped and a 400 with
    // "Record data cannot be empty".
    return {
      memberships: membershipIds,
      gender: toIdLabel(GENDER_OPTIONS, form.gender),
      pronouns: toIdLabel(PRONOUNS_OPTIONS, form.pronouns),
      birthday: form.birthday,
      city: form.city.trim(),
      regionalAccent: toIdLabel(REGIONAL_ACCENT_OPTIONS, form.regionalAccent),
      heritage: form.heritage.trim(),
      firstLanguage: form.firstLanguage.trim(),
      localDialect: form.localDialect,
      jobTitle: form.jobTitle.trim(),
      industry: [form.industry],
      position: [form.position],
      careerStage: [form.careerStage],
      income: [form.income],
      lookingFor: form.lookingFor,
      myGoal: form.myGoal.trim(),
    };
  };

  const handleConnectTikTok = () => {
    if (!user?.id) {
      toast.error("Not signed in");
      return;
    }
    if (updateRecord.enabled === false) {
      toast.error("Saving is disabled for this block. Check the Visibility / permissions tabs in Softr.");
      return;
    }

    setSaving(true);
    oauthPendingRef.current = true;

    // Fire the save. The OAuth redirect is now triggered inside the
    // onSuccess callback above, only once the server has confirmed
    // the write. No race with window.location.href.
    const updates = buildUpdates();
    console.log("=== onboarding save payload:", JSON.stringify(updates, null, 2));
    console.log("=== onboarding recordId:", user.id);
    console.log("=== onboarding updateRecord.enabled:", updateRecord.enabled);
    updateRecord.mutate({ recordId: user.id, fields: updates });
  };

  // ─── Render guards ─────────────────────────────────────────────
  if (!user?.id) {
    return (
      <div className="container py-12">
        <div className="content flex items-center justify-center min-h-[400px]">
          <div className="text-destructive">
            Please sign in to continue your onboarding.
          </div>
        </div>
      </div>
    );
  }

  const firstName =
    user.fullName?.trim().split(/\s+/)[0] || "there";

  const step = STEPS[stepIdx];
  const showBack = stepIdx > 0 && step.id !== "welcome";

  return (
    <>
      <Toaster />
      <div className="container py-10">
        <div className="content max-w-2xl mx-auto space-y-6">
          <ProgressBar current={stepIdx + 1} total={STEPS.length} />

          <Card className="bg-white" style={{ borderColor: CS_BORDER }}>
            <CardContent className="p-8 space-y-8">

              {/* ─── 1. Welcome ─── */}
              {step.id === "welcome" && (
                <>
                  <StepHeading
                    eyebrow="Welcome"
                    title={`Hey ${firstName}, let's get you set up.`}
                    description="A few quick questions to set up your account, then we'll connect your TikTok and you're in. Most people finish in under 3 minutes."
                  />
                  <div className="rounded-xl p-5 space-y-3" style={{ backgroundColor: CS_BORDER }}>
                    <div className="flex items-center gap-3 text-sm" style={{ color: CS_BLUE }}>
                      <Sparkles className="h-4 w-4" /> What we'll cover
                    </div>
                    <ul className="space-y-2 text-sm text-muted-foreground">
                      <li>• The content you post and your weekly commitment</li>
                      <li>• A few profile basics so we can match you to brands</li>
                      <li>• Connect TikTok at the end (we pull your handle from there)</li>
                    </ul>
                  </div>
                  <NavBar
                    onContinue={continueWelcome}
                    canContinue
                    showBack={false}
                    continueLabel="Let's go"
                  />
                </>
              )}


              {/* ─── 3. Track ─── */}
              {step.id === "track" && (
                <>
                  <StepHeading
                    eyebrow="Step 1"
                    title="What kind of content do you post?"
                    description="Pick everything you actually do. You can change this later."
                  />
                  <InfoToggle>
                    Doing well on TikTok comes down to consistency and
                    accountability. We help you stick to a weekly minimum so
                    you don't ghost your TikTok journey.
                    <br /><br />
                    Pick what you actually do. Shop creators must pick Shop,
                    Live creators must pick Live. If you want to push into
                    other content too, add it. We'll hold you accountable to
                    all of them.
                  </InfoToggle>
                  <div className="grid sm:grid-cols-3 gap-3">
                    {TRACK_OPTIONS.map((opt) => (
                      <TrackTile
                        key={opt.key}
                        option={opt}
                        selected={form.track.includes(opt.key)}
                        onToggle={() => toggleInArray("track", opt.key)}
                      />
                    ))}
                  </div>
                  <NavBar
                    onBack={goBack}
                    onContinue={continueTrack}
                    isSaving={saving}
                    canContinue={form.track.length > 0}
                    showBack={showBack}
                  />
                </>
              )}

              {/* ─── 4. Cadence (membership tier picker) ─── */}
              {step.id === "cadence" && (
                <>
                  <StepHeading
                    eyebrow="Step 2"
                    title="Pick your intensity."
                    description="For each one you picked, choose how often you'll show up."
                  />
                  <InfoToggle>
                    This is your weekly minimum. We always encourage posting
                    more, ideally multiple times a day. But pick what you can
                    realistically commit to.
                    <br /><br />
                    Drop below your minimum and you lose your streak.
                  </InfoToggle>
                  <div className="space-y-6">
                    {TRACK_OPTIONS.filter((t) => form.track.includes(t.key)).map((t) => {
                      const optionsForTrack = MEMBERSHIP_OPTIONS
                        .filter((opt) => opt.track === t.key)
                        .sort((a, b) => (TIER_ORDER[a.tier] ?? 99) - (TIER_ORDER[b.tier] ?? 99));
                      return (
                        <div key={t.key}>
                          <div className="flex items-center gap-3 mb-3">
                            <img
                              src={t.icon}
                              alt={t.label}
                              style={{
                                width: 36,
                                height: 36,
                                objectFit: "cover",
                                display: "block",
                                borderRadius: 9,
                              }}
                            />
                            <div className="font-semibold text-sm" style={{ color: CS_BLUE }}>
                              {t.label}
                            </div>
                          </div>
                          <div className="grid grid-cols-3 gap-2">
                            {optionsForTrack.map((opt) => {
                              const selected = form.membershipsByTrack[t.key] === opt.id;
                              return (
                                <button
                                  key={opt.id}
                                  type="button"
                                  onClick={() =>
                                    setForm((f) => ({
                                      ...f,
                                      membershipsByTrack: {
                                        ...f.membershipsByTrack,
                                        [t.key]: opt.id,
                                      },
                                    }))
                                  }
                                  className="text-left transition-all rounded-xl p-3 border-2"
                                  style={{
                                    borderColor: selected ? CS_PINK : CS_BORDER,
                                    backgroundColor: selected
                                      ? "rgba(254,44,85,0.04)"
                                      : "#fff",
                                  }}
                                >
                                  <div
                                    className="text-xs font-bold uppercase tracking-wider mb-1"
                                    style={{ color: selected ? CS_PINK : CS_BLUE }}
                                  >
                                    {opt.tier}
                                  </div>
                                  <div className="text-xs text-muted-foreground">
                                    {opt.cadence} {opt.unit}/wk
                                  </div>
                                </button>
                              );
                            })}
                          </div>
                        </div>
                      );
                    })}
                  </div>
                  <NavBar
                    onBack={goBack}
                    onContinue={continueCadence}
                    isSaving={saving}
                    canContinue={
                      TRACK_OPTIONS.filter((t) => form.track.includes(t.key)).every(
                        (t) => !!form.membershipsByTrack[t.key],
                      )
                    }
                    showBack={showBack}
                  />
                </>
              )}

              {/* ─── 5. About you ─── */}
              {step.id === "about" && (
                <>
                  <StepHeading
                    eyebrow="Step 3"
                    title="A bit about you"
                    description="So we can match you to the right brands and verify partnership eligibility."
                  />
                  <div className="grid sm:grid-cols-2 gap-4">
                    <div className="space-y-2">
                      <Label>Gender</Label>
                      <Select value={form.gender} onValueChange={(v) => set("gender", v)}>
                        <SelectTrigger><SelectValue placeholder="Pick one" /></SelectTrigger>
                        <SelectContent>
                          {GENDER_OPTIONS.map((o) => (
                            <SelectItem key={o.id} value={o.id}>{o.label}</SelectItem>
                          ))}
                        </SelectContent>
                      </Select>
                    </div>
                    <div className="space-y-2">
                      <Label>Pronouns</Label>
                      <Select value={form.pronouns} onValueChange={(v) => set("pronouns", v)}>
                        <SelectTrigger><SelectValue placeholder="Pick one" /></SelectTrigger>
                        <SelectContent>
                          {PRONOUNS_OPTIONS.map((o) => (
                            <SelectItem key={o.id} value={o.id}>{o.label}</SelectItem>
                          ))}
                        </SelectContent>
                      </Select>
                    </div>
                    <div className="space-y-2">
                      <Label>Birthday</Label>
                      <Input
                        type="date"
                        value={form.birthday}
                        onChange={(e) => set("birthday", e.target.value)}
                        max={getMaxBirthDate()}
                      />
                      <p className="text-xs text-muted-foreground">
                        You must be 18 or over to join Creator Scans.
                      </p>
                    </div>
                  </div>
                  <NavBar
                    onBack={goBack}
                    onContinue={continueAbout}
                    isSaving={saving}
                    canContinue={!!form.gender && !!form.pronouns && !!form.birthday}
                    showBack={showBack}
                  />
                </>
              )}

              {/* ─── 6. Where you're from ─── */}
              {step.id === "where" && (
                <>
                  <StepHeading
                    eyebrow="Step 4"
                    title="Where you're from"
                    description="So we can match you to regional brand campaigns and content opportunities."
                  />
                  <div className="grid sm:grid-cols-2 gap-4">
                    <div className="space-y-2">
                      <Label>City</Label>
                      <Input
                        value={form.city}
                        onChange={(e) => set("city", e.target.value)}
                        placeholder="Manchester"
                      />
                    </div>
                    <div className="space-y-2">
                      <Label>Regional accent</Label>
                      <Select value={form.regionalAccent} onValueChange={(v) => set("regionalAccent", v)}>
                        <SelectTrigger><SelectValue placeholder="Pick one" /></SelectTrigger>
                        <SelectContent>
                          {REGIONAL_ACCENT_OPTIONS.map((o) => (
                            <SelectItem key={o.id} value={o.id}>{o.label}</SelectItem>
                          ))}
                        </SelectContent>
                      </Select>
                    </div>
                    <div className="space-y-2">
                      <Label>Heritage</Label>
                      <Input
                        value={form.heritage}
                        onChange={(e) => set("heritage", e.target.value)}
                        placeholder="British-Ghanaian"
                      />
                    </div>
                    <div className="space-y-2">
                      <Label>First language</Label>
                      <Input
                        value={form.firstLanguage}
                        onChange={(e) => set("firstLanguage", e.target.value)}
                        placeholder="English"
                      />
                    </div>
                    <div className="sm:col-span-2 flex items-start gap-3 rounded-xl p-4" style={{ backgroundColor: CS_BORDER }}>
                      <Checkbox
                        id="localDialect"
                        checked={form.localDialect}
                        onCheckedChange={(c) => set("localDialect", !!c)}
                        className="mt-0.5"
                      />
                      <div>
                        <Label htmlFor="localDialect" className="cursor-pointer">
                          I post in my local dialect
                        </Label>
                        <p className="text-xs text-muted-foreground mt-0.5">
                          Tick this if you do. We'll use it to remix and write scripts in your voice. Leave it unticked and we'll use a neutral tone instead.
                        </p>
                      </div>
                    </div>
                  </div>
                  <NavBar
                    onBack={goBack}
                    onContinue={continueWhere}
                    isSaving={saving}
                    canContinue={
                      !!form.city.trim() &&
                      !!form.regionalAccent &&
                      !!form.heritage.trim() &&
                      !!form.firstLanguage.trim()
                    }
                    showBack={showBack}
                  />
                </>
              )}

              {/* ─── 7. Career ─── */}
              {step.id === "career" && (
                <>
                  <StepHeading
                    eyebrow="Step 5"
                    title="Your career"
                    description="So we can script content that fits your life and review your videos with the right context."
                  />
                  <InfoToggle>
                    We work with side-hustlers, full-time employees,
                    students, founders. Every kind of creator. The more we
                    know about your day-to-day, the better we can tailor
                    your scripts and content reviews to you.
                  </InfoToggle>
                  <div className="space-y-5">
                    <div className="space-y-2">
                      <Label>Job title</Label>
                      <Input
                        value={form.jobTitle}
                        onChange={(e) => set("jobTitle", e.target.value)}
                        placeholder="Marketing Manager"
                      />
                    </div>
                    <div className="space-y-2">
                      <Label>Industry</Label>
                      <Select value={form.industry} onValueChange={(v) => set("industry", v)}>
                        <SelectTrigger><SelectValue placeholder="Pick one" /></SelectTrigger>
                        <SelectContent>
                          {INDUSTRY_OPTIONS.map((o) => (
                            <SelectItem key={o.id} value={o.id}>{o.label}</SelectItem>
                          ))}
                        </SelectContent>
                      </Select>
                    </div>
                    <div className="space-y-2">
                      <Label>Position</Label>
                      <Select value={form.position} onValueChange={(v) => set("position", v)}>
                        <SelectTrigger><SelectValue placeholder="Pick one" /></SelectTrigger>
                        <SelectContent>
                          {POSITION_OPTIONS.map((o) => (
                            <SelectItem key={o.id} value={o.id}>{o.label}</SelectItem>
                          ))}
                        </SelectContent>
                      </Select>
                    </div>
                    <div className="space-y-2">
                      <Label>Career stage</Label>
                      <Select value={form.careerStage} onValueChange={(v) => set("careerStage", v)}>
                        <SelectTrigger><SelectValue placeholder="Pick one" /></SelectTrigger>
                        <SelectContent>
                          {CAREER_STAGE_OPTIONS.map((o) => (
                            <SelectItem key={o.id} value={o.id}>{o.label}</SelectItem>
                          ))}
                        </SelectContent>
                      </Select>
                    </div>
                    <div className="space-y-2">
                      <Label>Annual income</Label>
                      <Select value={form.income} onValueChange={(v) => set("income", v)}>
                        <SelectTrigger><SelectValue placeholder="Pick a band" /></SelectTrigger>
                        <SelectContent>
                          {INCOME_OPTIONS.map((o) => (
                            <SelectItem key={o.id} value={o.id}>{o.label}</SelectItem>
                          ))}
                        </SelectContent>
                      </Select>
                    </div>
                  </div>
                  <NavBar
                    onBack={goBack}
                    onContinue={continueCareer}
                    isSaving={saving}
                    canContinue={
                      !!form.jobTitle.trim() &&
                      !!form.industry &&
                      !!form.position &&
                      !!form.careerStage &&
                      !!form.income
                    }
                    showBack={showBack}
                  />
                </>
              )}

              {/* ─── 8. Why you're here ─── */}
              {step.id === "why" && (
                <>
                  <StepHeading
                    eyebrow="Step 6"
                    title="Why you're here"
                    description="So we can surface the right tools, perks, and brand opportunities for you."
                  />
                  <div className="space-y-5">
                    <div className="space-y-2">
                      <Label>What are you looking for? <span className="text-xs text-muted-foreground">(pick as many as apply)</span></Label>
                      <div className="flex flex-wrap gap-2">
                        {LOOKING_FOR_OPTIONS.map((o) => (
                          <MultiChip
                            key={o.id}
                            option={o}
                            selected={form.lookingFor.includes(o.id)}
                            onToggle={() => toggleInArray("lookingFor", o.id)}
                          />
                        ))}
                      </div>
                    </div>
                    <div className="space-y-2">
                      <Label htmlFor="myGoal">What's the big goal?</Label>
                      <Input
                        id="myGoal"
                        value={form.myGoal}
                        onChange={(e) => set("myGoal", e.target.value)}
                        placeholder="Quit my day job and go full-time on TikTok by next year."
                      />
                    </div>
                  </div>
                  <NavBar
                    onBack={goBack}
                    onContinue={continueWhy}
                    isSaving={saving}
                    canContinue={form.lookingFor.length > 0 && !!form.myGoal.trim()}
                    showBack={showBack}
                  />
                </>
              )}

              {/* ─── 9. Connect TikTok ─── */}
              {step.id === "connect" && (
                <>
                  <StepHeading
                    eyebrow="Last step"
                    title="Connect your TikTok."
                    description="We use TikTok's official auth to pull your bio, profile picture, and stats. We also send your TikTok Shop and Creator Network agency invite. Takes about 30 seconds."
                  />
                  <div className="space-y-3">
                    <div className="flex items-start gap-3 rounded-xl p-4" style={{ backgroundColor: CS_BORDER }}>
                      <Check className="h-5 w-5 mt-0.5 shrink-0" style={{ color: CS_BLUE }} />
                      <div className="text-sm" style={{ color: CS_BLUE }}>
                        Pulls your handle, bio, follower count and profile picture automatically.
                      </div>
                    </div>
                    <div className="flex items-start gap-3 rounded-xl p-4" style={{ backgroundColor: CS_BORDER }}>
                      <Check className="h-5 w-5 mt-0.5 shrink-0" style={{ color: CS_BLUE }} />
                      <div className="text-sm" style={{ color: CS_BLUE }}>
                        Triggers your TikTok Shop and Creator Network agency invite.
                      </div>
                    </div>
                    <div className="flex items-start gap-3 rounded-xl p-4" style={{ backgroundColor: CS_BORDER }}>
                      <Check className="h-5 w-5 mt-0.5 shrink-0" style={{ color: CS_BLUE }} />
                      <div className="text-sm" style={{ color: CS_BLUE }}>
                        Read-only. We can't post or DM as you.
                      </div>
                    </div>
                  </div>
                  <button
                    type="button"
                    onClick={handleConnectTikTok}
                    disabled={saving}
                    className="w-full flex items-center justify-center gap-3 rounded-xl px-6 py-5 font-bold transition-opacity"
                    style={{
                      backgroundColor: "#FE2C55",
                      color: "#fff",
                      fontSize: 17,
                      opacity: saving ? 0.6 : 1,
                      cursor: saving ? "wait" : "pointer",
                      border: "none",
                    }}
                  >
                    <img
                      src={ICONS.tiktokLogo}
                      alt=""
                      style={{ width: 32, height: 32, display: "block" }}
                    />
                    {saving ? "Saving and redirecting…" : "Connect TikTok"}
                  </button>
                  <div className="flex items-center justify-between pt-4">
                    <Button
                      variant="ghost"
                      onClick={goBack}
                      disabled={saving}
                      className="gap-2"
                    >
                      <ArrowLeft className="h-4 w-4" />
                      Back
                    </Button>
                    <p className="text-xs text-muted-foreground text-right">
                      You'll be redirected to TikTok to authorise. After approval you'll land back in the dashboard.
                    </p>
                  </div>
                </>
              )}

            </CardContent>
          </Card>
        </div>
      </div>
    </>
  );
}
